---- E:\1.workspace\7.other\17.charge_demo\charge_demo\06-release\SC8F096_Timer_Demo\SC8P096_Timer0_C.c ----------------------------------------------------------------------
1:                /*-------------------------------------------
2:                
3:                程序名称：Timer0定时中断程序
4:                日期版本：2024/09/14 <V1.0>
5:                
6:                备注：   
7:                
8:                *本程序由 &应用支持部& 编写整理
9:                -------------------------------------------*/
10:               #include <sc.h>					//芯片头文件，会根据工程选项自动寻找对应型号头文件
11:               static unsigned int timer_cnt = 0;
12:               
13:               void gpio_init(void)
14:               {
15:               	//RA0输出高电平
16:               	TRISA = 0B11111110;//RA0 方向:输出
  0052    30FE    LDIA	0xFE
  0053    0085    LD	0x5,A
17:               	PORTA = 0B00000001;//RA0 电平:高
  0054    3001    LDIA	0x1
  0055    0086    LD	0x6,A
  0056    0008    RET
18:               }
19:               
20:               void test_io_high()
21:               {
22:               	PORTA |= 0B00000001;//RA0 电平:高
23:               }
24:               
25:               void test_io_low()
26:               {
27:               	PORTA &= 0B11111110;//RA0 电平:低
28:               }
29:               
30:               void control_test_io(unsigned int flag)
31:               {
32:               	if(flag)
33:               	{
34:               		test_io_high();
35:               	}
36:               	else
37:               	{
38:               		test_io_low();
39:               	}
40:               }
41:               
42:               void main(void)
  0015    0000    NOP
  0016    0064    CLRWDT
43:               {
44:               	asm("nop");
45:               	asm("clrwdt");
46:               	OSCCON = 0x72;				//16MHZ,内部振荡器用作系统时钟,CONFIG关闭WDT时软件可以控制WDT开关
  0017    3072    LDIA	0x72
  0018    1283    CLRB	0x3,5
  0019    1303    CLRB	0x3,6
  001A    0094    LD	0x14,A
47:               	OPTION_REG = 0x00;			//配置TIMER0时间，00为2分频
  001B    0181    CLR	0x1
  001C    0064    CLRWDT
48:               	asm("clrwdt");
49:               	/*********************************************************************
50:               	预分频器控制寄存器 OPTION_REG（01H）
51:               	Bit7  未用 
52:               	Bit6  INTEDG:  触发中断的边沿选择位
53:               		1=  INT 引脚上升沿触发中断
54:               		0=  INT 引脚下降沿触发中断
55:               	Bit5  T0CS:  TIMER0 时钟源选择位
56:               		0=  内部指令周期时钟（FSYS /4）
57:               		1=	T0CKI 引脚上的跳变沿
58:               	Bit4  T0SE:	TIMER0 时钟源边沿选择位。
59:               		0=	在 T0CKI 引脚信号从低电平跳变到高电平时递增
60:               		1=	在 T0CKI 引脚信号从高电平跳变到低电平时递增
61:               	Bit3  PSA: 预分频器分配位
62:               		0=	预分频器分配给 TIMER0 模块
63:               		1=	预分频器分配给 WDT
64:               	Bit2~Bit0  PS2~PS0:  预分配参数配置位
65:               		PS2  PS1  PS0  TMR0分频比  WDT 分频比 
66:               		0    0    0  	1:2  		1:1 
67:               		0  	 0	  1		1:4			1:2 
68:               		0	 1	  0		1:8			1:4 
69:               		0	 1	  1		1:16		1:8 
70:               		1  	 0	  0		1:32		1:16 
71:               		1	 0	  1		1:64		1:32 
72:               		1	 1	  0		1:128		1:64 
73:               		1	 1	  1		1:256		1:128 
74:               	*********************************************************************/
75:               	
76:               	
77:               	WPUA = 0B00000000;
  001D    1683    SETB	0x3,5
  001E    1303    CLRB	0x3,6
  001F    0188    CLR	0x8
78:               	WPDA = 0B00000000;
  0020    0187    CLR	0x7
79:               	
80:               	IOCA = 0B00000000;
  0021    0189    CLR	0x9
81:               	TRISA = 0B00000000;
  0022    0185    CLR	0x5
82:               	
83:               	WPUB = 0B00000000;
  0023    1283    CLRB	0x3,5
  0024    0188    CLR	0x8
84:               	WPDB = 0B00000000;
  0025    0187    CLR	0x7
85:               
86:               	IOCB = 0B00000000;
  0026    0189    CLR	0x9
87:               	TRISB = 0B00000000;
  0027    0185    CLR	0x5
88:               	
89:               	
90:               	TMR0 = 6;					//设定Timer初始值，计时时间为（256-6）*4*2/16M=125uS
  0028    3006    LDIA	0x6
  0029    1683    SETB	0x3,5
  002A    0081    LD	0x1,A
91:               	T0IF = 0;
  002B    110B    CLRB	0xB,2
92:               	T0IE = 1;					//使能Timer0溢出中断
  002C    168B    SETB	0xB,5
93:               	
94:               	GIE = 1;					//开启总中断
  002D    178B    SETB	0xB,7
95:               	gpio_init();
  002E    120A    CLRB	0xA,4
  002F    118A    CLRB	0xA,3
  0030    2052    CALL	0x52
96:               	while(1)
  0033    0064    CLRWDT
  0034    2833    JP	0x33
97:               	{
98:               		asm("clrwdt");
99:               	}
100:              }
101:              /***********************************************
102:              函数名称：Timer0_Isr
103:              函数功能：中断服务
104:              入口参数：无
105:              出口参数：无
106:              备注：
107:              ************************************************/
108:              void interrupt Timer0_Isr(void)
109:              {
110:              	if(T0IF)
  0035    1D0B    SNZB	0xB,2
  0036    2842    JP	0x42
111:              	{
112:              		TMR0 += 6;			//TMR0不能自动赋值，操作TMR0的时候,TIME是不计数的
  0037    3006    LDIA	0x6
  0038    1683    SETB	0x3,5
  0039    1303    CLRB	0x3,6
  003A    0781    ADDR	0x1
113:              		T0IF = 0;
  003B    110B    CLRB	0xB,2
114:              		
115:              		PORTB ^= 0XFF;
  003C    30FF    LDIA	0xFF
  003D    1283    CLRB	0x3,5
  003E    0686    XORR	0x6
116:              		timer_cnt ++;
  003F    0AF0    INCR	0x70
  0040    1903    SZB	0x3,2
  0041    0AF1    INCR	0x71
117:              	}
118:              	if(timer_cnt > 8000)
  0042    301F    LDIA	0x1F
  0043    0271    SUBA	0x71
  0044    3041    LDIA	0x41
  0045    1903    SZB	0x3,2
  0046    0270    SUBA	0x70
  0047    1C03    SNZB	0x3,0
  0048    284B    JP	0x4B
119:              	{
120:              		timer_cnt = 0;
  0049    01F0    CLR	0x70
  004A    01F1    CLR	0x71
  004B    0873    LD	A,0x73
  004C    008A    LD	0xA,A
  004D    0E72    SWAPA	0x72
  004E    0083    LD	0x3,A
  004F    0EFE    SWAPR	0x7E
  0050    0E7E    SWAPA	0x7E
  0051    0009    RETI
121:              	}
122:              }
123:              
