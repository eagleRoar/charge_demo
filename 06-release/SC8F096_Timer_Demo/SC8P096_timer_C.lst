  0006    00F6    LD	0x76,A
  0007    080A    LD	A,0xA
  0008    00F7    LD	0x77,A
  0009    120A    CLRB	0xA,4
  000A    118A    CLRB	0xA,3
  000B    2817    JP	0x17
---- common_function ------------------------------------------------------------------
  0013    0183    CLR	0x3
  0014    120A    CLRB	0xA,4
  0015    118A    CLRB	0xA,3
  0016    284D    JP	0x4D
