---- E:\1.workspace\7.other\17.charge_demo\charge_demo\06-release\SC8F096_Timer_Demo\SC8P096_Timer0_C.c ----------------------------------------------------------------------
1:                /*-------------------------------------------
2:                
3:                程序名称：Timer0定时中断程序
4:                日期版本：2024/09/14 <V1.0>
5:                
6:                备注：   
7:                
8:                *本程序由 &应用支持部& 编写整理
9:                -------------------------------------------*/
10:               #include <sc.h>					//芯片头文件，会根据工程选项自动寻找对应型号头文件
11:               static unsigned int timer_cnt = 0;
12:               static unsigned int level = 0;
13:               
14:               void gpio_init(void)
15:               {
16:               	//RA0输出高电平
17:               	TRISA = 0B11111110;//RA0 方向:输出
  006D    30FE    LDIA	0xFE
  006E    0085    LD	0x5,A
18:               	PORTA = 0B0000001;//RA0 电平:高
  006F    3001    LDIA	0x1
  0070    0086    LD	0x6,A
  0071    0008    RET
19:               }
20:               
21:               void test_io_high()
22:               {
23:               	PORTA |= 0B00000001;//RA0 电平:高
  0045    1683    SETB	0x3,5
  0046    1303    CLRB	0x3,6
  0047    1406    SETB	0x6,0
  0048    0008    RET
24:               }
25:               
26:               void test_io_low()
27:               {
28:               	PORTA &= 0B11111110;//RA0 电平:低
  0049    1683    SETB	0x3,5
  004A    1303    CLRB	0x3,6
  004B    1006    CLRB	0x6,0
  004C    0008    RET
29:               }
30:               
31:               void control_test_io(unsigned int flag)
32:               {
33:               	if(flag)
  003F    0874    LD	A,0x74
  0040    0475    ORA	0x75
  0041    1903    SZB	0x3,2
  0042    2844    JP	0x44
34:               	{
35:               		test_io_high();
  0043    2845    JP	0x45
36:               	}
37:               	else
38:               	{
39:               		test_io_low();
  0044    2849    JP	0x49
40:               	}
41:               }
42:               
43:               void main(void)
  004D    0000    NOP
  004E    0064    CLRWDT
44:               {
45:               	asm("nop");
46:               	asm("clrwdt");
47:               	OSCCON = 0x72;				//16MHZ,内部振荡器用作系统时钟,CONFIG关闭WDT时软件可以控制WDT开关
  004F    3072    LDIA	0x72
  0050    1283    CLRB	0x3,5
  0051    1303    CLRB	0x3,6
  0052    0094    LD	0x14,A
48:               	OPTION_REG = 0x00;			//配置TIMER0时间，00为2分频
  0053    0181    CLR	0x1
  0054    0064    CLRWDT
49:               	asm("clrwdt");
50:               	/*********************************************************************
51:               	预分频器控制寄存器 OPTION_REG（01H）
52:               	Bit7  未用 
53:               	Bit6  INTEDG:  触发中断的边沿选择位
54:               		1=  INT 引脚上升沿触发中断
55:               		0=  INT 引脚下降沿触发中断
56:               	Bit5  T0CS:  TIMER0 时钟源选择位
57:               		0=  内部指令周期时钟（FSYS /4）
58:               		1=	T0CKI 引脚上的跳变沿
59:               	Bit4  T0SE:	TIMER0 时钟源边沿选择位。
60:               		0=	在 T0CKI 引脚信号从低电平跳变到高电平时递增
61:               		1=	在 T0CKI 引脚信号从高电平跳变到低电平时递增
62:               	Bit3  PSA: 预分频器分配位
63:               		0=	预分频器分配给 TIMER0 模块
64:               		1=	预分频器分配给 WDT
65:               	Bit2~Bit0  PS2~PS0:  预分配参数配置位
66:               		PS2  PS1  PS0  TMR0分频比  WDT 分频比 
67:               		0    0    0  	1:2  		1:1 
68:               		0  	 0	  1		1:4			1:2 
69:               		0	 1	  0		1:8			1:4 
70:               		0	 1	  1		1:16		1:8 
71:               		1  	 0	  0		1:32		1:16 
72:               		1	 0	  1		1:64		1:32 
73:               		1	 1	  0		1:128		1:64 
74:               		1	 1	  1		1:256		1:128 
75:               	*********************************************************************/
76:               	
77:               	
78:               	WPUA = 0B00000000;
  0055    1683    SETB	0x3,5
  0056    1303    CLRB	0x3,6
  0057    0188    CLR	0x8
79:               	WPDA = 0B00000000;
  0058    0187    CLR	0x7
80:               	
81:               	IOCA = 0B00000000;
  0059    0189    CLR	0x9
82:               	TRISA = 0B00000000;
  005A    0185    CLR	0x5
83:               	
84:               	WPUB = 0B00000000;
  005B    1283    CLRB	0x3,5
  005C    0188    CLR	0x8
85:               	WPDB = 0B00000000;
  005D    0187    CLR	0x7
86:               
87:               	IOCB = 0B00000000;
  005E    0189    CLR	0x9
88:               	TRISB = 0B00000000;
  005F    0185    CLR	0x5
89:               	
90:               	
91:               	TMR0 = 6;					//设定Timer初始值，计时时间为（256-6）*4*2/16M=125uS
  0060    3006    LDIA	0x6
  0061    1683    SETB	0x3,5
  0062    0081    LD	0x1,A
92:               	T0IF = 0;
  0063    110B    CLRB	0xB,2
93:               	T0IE = 1;					//使能Timer0溢出中断
  0064    168B    SETB	0xB,5
94:               	
95:               	GIE = 1;					//开启总中断
  0065    178B    SETB	0xB,7
96:               	gpio_init();
  0066    120A    CLRB	0xA,4
  0067    118A    CLRB	0xA,3
  0068    206D    CALL	0x6D
97:               	while(1)
  006B    0064    CLRWDT
  006C    286B    JP	0x6B
98:               	{
99:               		asm("clrwdt");
100:              	}
101:              }
102:              /***********************************************
103:              函数名称：Timer0_Isr
104:              函数功能：中断服务
105:              入口参数：无
106:              出口参数：无
107:              备注：
108:              ************************************************/
109:              void interrupt Timer0_Isr(void)
110:              {
111:              	if(T0IF)
  0017    1D0B    SNZB	0xB,2
  0018    2824    JP	0x24
112:              	{
113:              		TMR0 += 6;			//TMR0不能自动赋值，操作TMR0的时候,TIME是不计数的
  0019    3006    LDIA	0x6
  001A    1683    SETB	0x3,5
  001B    1303    CLRB	0x3,6
  001C    0781    ADDR	0x1
114:              		T0IF = 0;
  001D    110B    CLRB	0xB,2
115:              		
116:              		PORTB ^= 0XFF;
  001E    30FF    LDIA	0xFF
  001F    1283    CLRB	0x3,5
  0020    0686    XORR	0x6
117:              		timer_cnt ++;
  0021    0AF2    INCR	0x72
  0022    1903    SZB	0x3,2
  0023    0AF3    INCR	0x73
118:              	}
119:              	if(timer_cnt > 8000)
  0024    301F    LDIA	0x1F
  0025    0273    SUBA	0x73
  0026    3041    LDIA	0x41
  0027    1903    SZB	0x3,2
  0028    0272    SUBA	0x72
  0029    1C03    SNZB	0x3,0
  002A    2838    JP	0x38
120:              	{
121:              		timer_cnt = 0;
  002B    01F2    CLR	0x72
  002C    01F3    CLR	0x73
122:              		control_test_io((level++)%2);
  002D    0871    LD	A,0x71
  002E    00F5    LD	0x75,A
  002F    0870    LD	A,0x70
  0030    00F4    LD	0x74,A
  0031    3001    LDIA	0x1
  0032    05F4    ANDR	0x74
  0033    01F5    CLR	0x75
  0034    203F    CALL	0x3F
  0035    0AF0    INCR	0x70
  0036    1903    SZB	0x3,2
  0037    0AF1    INCR	0x71
  0038    0877    LD	A,0x77
  0039    008A    LD	0xA,A
  003A    0E76    SWAPA	0x76
  003B    0083    LD	0x3,A
  003C    0EFE    SWAPR	0x7E
  003D    0E7E    SWAPA	0x7E
  003E    0009    RETI
123:              	}
124:              }
125:              
