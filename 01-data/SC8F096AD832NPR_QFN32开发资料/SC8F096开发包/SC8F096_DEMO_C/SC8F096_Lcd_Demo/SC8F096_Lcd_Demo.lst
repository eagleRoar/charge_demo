74:               void interrupt Timer_Isr()
75:               {
76:               	static unsigned char tcount = 0;
77:               	
78:               	if(TMR2IF)
  0089    1283    CLRB	0x3,5
  008A    1303    CLRB	0x3,6
  008B    1C8D    SNZB	0xD,1
  008C    2895    JP	0x95
79:               	{
80:               		TMR2IF = 0;
  008D    108D    CLRB	0xD,1
81:               		if(++tcount >= 40)					//主循环定时设置为40*125us=5ms
  008E    3028    LDIA	0x28
  008F    0AF4    INCR	0x74
  0090    0274    SUBA	0x74
  0091    1C03    SNZB	0x3,0
  0092    2895    JP	0x95
