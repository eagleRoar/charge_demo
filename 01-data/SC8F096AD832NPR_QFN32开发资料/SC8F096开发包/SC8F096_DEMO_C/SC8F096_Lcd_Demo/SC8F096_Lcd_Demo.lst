113:              /**********************************************************
114:              函数名称：Set_LCD_Moudle
115:              函数功能：初始化LED/LCD模块设置
116:              入口参数：无
117:              出口参数：无 
118:              备    注：
119:              **********************************************************/
120:              void Set_LCD_Moudle()
121:              {
122:              	TRISA |= 0XFF;			//LCD_SEG
  004D    30FF    LDIA	0xFF
  004E    1683    SETB	0x3,5
  004F    1303    CLRB	0x3,6
  0050    0085    LD	0x5,A
123:              	TRISB |= 0XFF;			//LCD_SEG
  0051    1283    CLRB	0x3,5
  0052    0085    LD	0x5,A
124:              	TRISC |= (0X0F);		//LCD_COM
  0053    300F    LDIA	0xF
  0054    1703    SETB	0x3,6
  0055    0485    ORR	0x5
125:              	TRISD |= (0XFF);		//LCD_SEG
  0056    30FF    LDIA	0xFF
  0057    0094    LD	0x14,A
126:              	CC0_RD	=	0;		//1= 使能下拉,如用RC2,3做LCD COM则必须关闭该口下拉
  0058    1683    SETB	0x3,5
  0059    1095    CLRB	0x15,1
127:              	CC1_RD	=	0;		//1= 使能下拉
  005A    1096    CLRB	0x16,1
128:              	LCDCON0 = 0B00010100;			//使能LCD,设置为4个COM,设置频率为FHSI/16384	
  005B    3014    LDIA	0x14
  005C    1283    CLRB	0x3,5
  005D    009D    LD	0x1D,A
129:              	/******* LEDCON0*****************************
130:              	Bit7  LCDEN:  LCD 模块使能
131:              		0:  禁止 LCD 模块
132:              		1:  使能 LCD 模块
133:              	Bit6  LEDEN:  LED 模块使能
134:              		0:  禁止 LED 模块
135:              		1:  使能 LED 模块。
136:              	Bit5~Bit3  COMSEL[2:0]:  LCD/LED 模块 COM 口个数选择
137:              			LCD 扫描模式  LED 扫描模式
138:              		000:  2COM 		 3COM
139:              		001:  3COM  	 4COM
140:              		010:  4COM  	 5COM
141:              		011:  5COM		 6COM
142:              		100:  6COM		 7COM
143:              		101:  6COM		 8COM
144:              		110:  6COM 		 9COM
145:              		111:  6COM		 10COM
146:              	Bit2~Bit0  LCDCLK[2:0]:  LCD/LED 扫描频率（根据 LCDCON1 的 LCDF<1:0>选择时钟源）
147:              				LED 扫描模式
148:              		000：  F HSI /1024||F LSI /2||F LSE /2
149:              		001：  F HSI /2048||F LSI /4||F LSE /4
150:              		010：  F HSI /4096||F LSI /8||F LSE /8
151:              		011：  F HSI /8192||F LSI /16||F LSE /16
152:              		100：  F HSI /16384||F LSI /32||F LSE /32
153:              		101：  F HSI /32768||F LSI /64||F LSE /64
154:              		110：  F HSI /65536||F LSI /128||F LSE /128
155:              		111：  F HSI /131072||F LSI /256||F LSE /256
156:              	**************************************************************************/
157:              	LCDCON1 = 0B01000000;					//1/3Bias,时钟源为FHSI
  005E    3040    LDIA	0x40
  005F    009E    LD	0x1E,A
158:              	/***************LCDCON1************************************************
159:              	Bit7  未用 
160:              	Bit6  BIAS:  LCD 偏置电压选择
161:              		0=  1/2BIAS
162:              		1=  1/3BIAS
163:              	Bit5~Bit4  未用 
164:              	Bit3~Bit2  FCCTLM<1:0>:  LCD 模式快速充电模式时间控制位
165:              		00=  1/8 COM 周期
166:              		01=  1/16 COM 周期
167:              		10=  1/32 COM 周期
168:              		11=  1/64 COM 周期
169:              	Bit1~Bit0  LCDF<1:0>:  LCD/LED 时钟源选择
170:              		0x:  F HSI
171:              		10:  F LSI
172:              		11:  F LSE
173:              	************************************************************************/
174:              	COMEN  = 0B00001111;			//COMEN的Bit0~5对应COM0~5
  0060    300F    LDIA	0xF
  0061    1683    SETB	0x3,5
  0062    009E    LD	0x1E,A
175:              	SEGEN0 = 0xff;					//SEGEN0对应SEG0~7
  0063    30FF    LDIA	0xFF
  0064    1303    CLRB	0x3,6
  0065    009E    LD	0x1E,A
176:              	SEGEN1 = 0xff;					//SEGEN1对应SEG8~15
  0066    1283    CLRB	0x3,5
  0067    1703    SETB	0x3,6
  0068    009F    LD	0x1F,A
177:              	SEGEN2 = 0xff;					//SEGEN1对应SEG16~23
  0069    1683    SETB	0x3,5
  006A    0081    LD	0x1,A
178:              	SEGEN3 = 0B01000000;			//SEG驱动电流选择为8mA
  006B    3040    LDIA	0x40
  006C    009F    LD	0x1F,A
179:              	/******************SEGEN3*******************************************
180:              	Bit7~Bit3  SEGDRI[4:0]:  SEG 口驱动电流设置
181:              		00000:  SEG 口驱动电流为 0mA
182:              		00001:  SEG 口驱动电流为 1mA
183:              		00010:  SEG 口驱动电流为 2mA
184:              		00011:  SEG 口驱动电流为 3mA
185:              		00100:  SEG 口驱动电流为 4mA
186:              		00101:  SEG 口驱动电流为 5mA
187:              		00110:  SEG 口驱动电流为 6mA
188:              		00111:  SEG 口驱动电流为 7mA
189:              		01000:  SEG 口驱动电流为 8mA
190:              		… 
191:              		11101:  SEG 口驱动电流为 29mA
192:              		11110:  SEG 口驱动电流为 30mA
193:              		11111:  SEG 口驱动电流为 45mA
194:              	Bit2~Bit1  未用 
195:              	Bit0  LCDDATA<8>:  LED 模式下，LED 数据的第 8 位
196:              	*******************************************************************/
197:              	LCDADD = 0B00000000;	//LCD功能内部分压电阻R = 10K
  006D    019C    CLR	0x1C
198:              							//如休眠状态需要点屏，建议分压电阻R 选择200K或900K
199:              	/***************LCDADD*******************
200:              	Bit7  LCDCS:  LCD/LED 数据读写使能
201:              		0:  禁止读写 LCD/LED 数据
202:              		1:  允许读写 LCD/LED 数据
203:              	Bit6~Bit5  B2RES<1:0>:  LCD 模式内部分压电阻选择
204:              		00=  R=10K
205:              		01=  R=50K
206:              		10=  R=200K(自动使能快速充电模式，在一个 COM 周期开始时 50K、200K 分压电阻同
207:              			时有效，经设定时间后 50K 分压电阻关闭，200K 分压电阻保持有效)
208:              		11=  R=900K(自动使能快速充电模式，在一个 COM 周期开始时 50K、900K 分压电阻同
209:              			时有效，经设定时间后 50K 分压电阻关闭，900K 分压电阻保持有效)
210:              		Bit4~Bit0  LCDADD<4:0>:  LCD/LED 地址选择
211:              								LCD/LED 地址范围 00H-017H
212:              	***********************************************************/
213:              	LCDEN = 1;				//1: 使能LCD模块
  006E    1283    CLRB	0x3,5
  006F    179D    SETB	0x1D,7
  0070    0008    RET
214:              }
