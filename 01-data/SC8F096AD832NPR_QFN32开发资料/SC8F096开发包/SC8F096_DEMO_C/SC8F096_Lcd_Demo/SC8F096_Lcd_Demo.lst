90:               /**********************************************************
91:               函数名称：void UpData(unsigned char Val)
92:               函数功能：点LCD屏
93:               入口参数：无
94:               出口参数：无 
95:               备    注：
96:               **********************************************************/
97:               
98:               void UpData(unsigned char Val)	
99:               {
100:              	volatile unsigned char i;
101:              			
102:              	for(i=0;i<=23;i++)
  0072    01F3    CLR	0x73
  0073    3018    LDIA	0x18
  0074    0273    SUBA	0x73
  0075    1803    SZB	0x3,0
  0076    2885    JP	0x85
103:              	{
104:              		
105:              		LCDCS=1; 	//允许读写LCD数据
  0077    1683    SETB	0x3,5
  0078    1703    SETB	0x3,6
  0079    179C    SETB	0x1C,7
106:              		LCDADD = (unsigned char)(LCDADD & 0xE0 | i);
  007A    081C    LD	A,0x1C
  007B    39E0    ANDIA	0xE0
  007C    0473    ORA	0x73
  007D    009C    LD	0x1C,A
107:              		LCDDATA = Val;
  007E    0872    LD	A,0x72
  007F    009D    LD	0x1D,A
  0080    0AF3    INCR	0x73
  0081    3018    LDIA	0x18
  0082    0273    SUBA	0x73
  0083    1C03    SNZB	0x3,0
  0084    2877    JP	0x77
108:              	}
109:              	LCDCS=0;	//禁止读写LCD数据
  0085    1683    SETB	0x3,5
  0086    1703    SETB	0x3,6
  0087    139C    CLRB	0x1C,7
  0088    0008    RET
110:              }
