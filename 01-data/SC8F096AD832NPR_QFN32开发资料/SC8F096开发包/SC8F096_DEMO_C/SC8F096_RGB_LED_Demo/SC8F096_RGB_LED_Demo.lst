  00A4    128E    CLRB	0xE,5
171:              	LEDCTR1 = 0X80;
  00A5    3080    LDIA	0x80
  00A6    008F    LD	0xF,A
172:              	for(i=0;i<5;i++)		//如有中断产生，则中断处理时间加写LED数据时间需小于15个字节的数据发送时间
  00A7    01F8    CLR	0x78
