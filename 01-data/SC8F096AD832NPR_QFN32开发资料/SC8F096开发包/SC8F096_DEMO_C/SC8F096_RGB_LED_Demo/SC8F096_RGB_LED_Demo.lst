  0095    0872    LD	A,0x72
  0096    009B    LD	0x1B,A
162:              		LEDCTR1 ++;
  0097    0A8F    INCR	0xF
  0098    300A    LDIA	0xA
  0099    0AF8    INCR	0x78
  009A    0278    SUBA	0x78
  009B    1C03    SNZB	0x3,0
  009C    288F    JP	0x8F
163:              	}
164:              	LEDSW_ST = 1;
  009D    140E    SETB	0xE,0
165:              	
166:              	while(IF_15==0)			//等待发完15个字节数据，
  009E    1683    SETB	0x3,5
  009F    1703    SETB	0x3,6
  00A0    1A8E    SZB	0xE,5
  00A1    28A4    JP	0xA4
  00A2    0064    CLRWDT
  00A3    289E    JP	0x9E
