146:              		1=使能读写数据缓存
147:              		0=禁止读写数据缓存
148:              	Bit6~Bit5  未用
149:              	Bit4~Bit0  LEDSW_ADD<4:0>	数据缓存地址选择
150:              		00000=  第1字节数据缓存地址
151:              		…
152:              		11101=	第30字节数据缓存地址
153:              	***************************************************/
154:              	LEDSW_RT = 1;
  008D    170E    SETB	0xE,6
