91:               /**********************************************************
92:               函数名称：Set_LED_Moudle
93:               函数功能：初始化LED/LCD模块设置
94:               入口参数：无
95:               出口参数：无 
96:               备    注：
97:               **********************************************************/
98:               void Set_LED_Moudle()
99:               {
100:              	LEDCTR0 = 0B11000000;			//使能驱动模块和重发模式,设置码率
  0119    30C0    LDIA	0xC0
  011A    1683    SETB	0x3,5
  011B    008E    LD	0xE,A
101:              	/***********LEDCTR0*********************************
102:              	Bit7  LEDSWE:	RGB彩灯驱动模块使能位
103:              		1=	使能RGB彩灯驱动模块
104:              		0=	关闭RGB彩灯驱动模块
105:              	Bit6  LEDSW_RT:	重发模式使能位
106:              		1=	使能重发模式
107:              		0=	关闭重发模式
108:              	Bit5  IF_15:	发码完成标志位
109:              		1=  已完成发码15个字节（第1到15字节），需软件清零才能重发
110:              		（第1到15字节）
111:              		0=  未完成发码15个字节
112:              	Bit4  IF_30:	发码完成标志位
113:              		1=  已完成发码30个字节（第1到30字节），需软件清零才能重发
114:              		（第16到30字节）
115:              		0=	未完成发码30个字节
116:              	Bit3  RESET_T:	RESET时间选择
117:              		1=	300us
118:              		0=	100us
119:              	Bit2~Bit1  LEDSW_CKSEL<1:0>:	码元格式选择
120:              		11=	T0H=500ns，T0L=2000ns；T1H=2000ns，T1L=500ns
121:              		10=	T0H=312.5ns，T0L=875ns；T1H=875ns，T1L=875ns
122:              		01=	T0H=250ns，T0L=1000ns；T1H=875ns，T1L=375ns
123:              		00=	T0H=312.5ns，T0L=625ns；T1H=625ns，T1L=312.5ns
124:              	Bit0  LEDSW_ST:	发码启动位
125:              		1=	启动发码，发码完成后硬件自动清零
126:              		0=禁止发码
127:              ******************************************************/
128:              	TRISA5 =0;
  011C    1303    CLRB	0x3,6
  011D    1285    CLRB	0x5,5
  011E    0008    RET
129:              	
130:              }
131:              
