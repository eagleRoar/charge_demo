66:               /***********************************************
67:               函数名称：Init_System
68:               函数功能：系统初始化
69:               入口参数：无
70:               出口参数：无
71:               备注：
72:               ************************************************/
73:               void Init_System()
74:               {
75:               	asm("nop");
76:               	asm("clrwdt");
77:               	INTCON = 0;					//系统初始化
  0025    018B    CLR	0xB
78:               	OSCCON = 0X70;				//配置振荡为8M,
  0026    3070    LDIA	0x70
  0027    1283    CLRB	0x3,5
  0028    1303    CLRB	0x3,6
  0029    0094    LD	0x14,A
79:               	OPTION_REG = 0;
  002A    0181    CLR	0x1
80:               	
81:                   WPUA  = 0B00000000;			//初始化上拉
  002B    1683    SETB	0x3,5
  002C    0188    CLR	0x8
82:                   WPUB  = 0B00001000;			
  002D    3008    LDIA	0x8
  002E    1283    CLRB	0x3,5
  002F    0088    LD	0x8,A
83:                 
84:                
85:               	TRISA = 0B00000000;			//初始化IO状态
  0030    1683    SETB	0x3,5
  0031    0185    CLR	0x5
86:               	TRISB = 0B00011000;
  0032    3018    LDIA	0x18
  0033    1283    CLRB	0x3,5
  0034    0085    LD	0x5,A
87:               
88:               	PORTA = 0B00000000;
  0035    1683    SETB	0x3,5
  0036    0186    CLR	0x6
89:               	PORTB = 0B00000000;			//初始化输出
  0037    1283    CLRB	0x3,5
  0038    0186    CLR	0x6
90:               	
91:               	/**************   TXSTA   **************************************
92:               		Bit7 CSRC: 时钟源选择位；  异步模式: 任意值；  同步模式:  
93:               			1=主控模式（由内部BRG产生时钟信号）；  
94:               			0=从动模式（由外部时钟源产生时钟）。 
95:               		Bit6 TX9EN: 9位发送使能位；  
96:               			1= 选择9位发送；  
97:               			0= 选择8位发送。 
98:               		Bit5 TXEN: 发送使能位(1)；  
99:               			1= 使能发送；  
100:              			0= 禁止发送。 
101:              		Bit4 SYNC: USART模式选择位；  
102:              			1= 同步模式；  
103:              			0= 异步模式。 
104:              		Bit3 SCKP: 同步时钟极性选择位。  
105:              			异步模式:  
106:              				1=将数据字符的电平取反后发送到TX/CK引脚；  
107:              				0=直接将数据字符发送到TX/CK引脚。  
108:              			同步模式:  
109:              				0=在时钟上升沿传输数据；  
110:              				1=在时钟下降沿传输数据。 
111:              		Bit2 STOPBIT: 停止位选择（仅对异步发送有效），当通过判断TRMT=1来送数据时，此位需写0。  
112:              			1= 1位停止位；  
113:              			0= 2位停止位。 
114:              		Bit1 TRMT: 发送移位寄存器状态位；  
115:              			1= TSR为空；  
116:              			0= TSR为满。 
117:              		Bit0 TX9D: 发送数据的第9位。 可以是地址/数据位或奇偶校验位
118:              	***********************************************************************/
119:              	TXSTA0 =  0B10100000;		//主控模式，8位数据，异步模式，
  0039    30A0    LDIA	0xA0
  003A    1703    SETB	0x3,6
  003B    0098    LD	0x18,A
120:              	
121:              	/*****************  RCSTA   ***********************************************
122:              		Bit7 SPEN: 串行端口使能位；  
123:              			1= 使能串行端口（将RX/DT和TX/CK引脚配置为串行端口引脚）； 
124:              			0= 禁止串行端口（保持在复位状态）。 
125:              		Bit6 RX9EN: 9位接收使能位；  
126:              			1= 选择9位接收；  
127:              			0= 选择8位接收。 
128:              		Bit5 SREN: 单字节接收使能位。  
129:              			异步模式: 任意值。  
130:              			同步主控模式:  
131:              				1=使能单字节接收；  
132:              				0=禁止单字节接收。 接收完成后清零该位。  
133:              			同步从动模式: 任意值。 
134:              		Bit4 CREN: 连续接收使能位。  
135:              			异步模式:  
136:              				1=使能接收；  
137:              				0=禁止接收。  
138:              			同步模式:  
139:              				1=使能连续接收直到清零CREN使能位（CREN覆盖SREN）；  
140:              				0=禁止连续接收。 
141:              		Bit3 RCIDL: 接收空闲标志位。  
142:              			异步模式: 
143:              				1=接收器空闲；  
144:              				0=已接收到起始位，接收器正在接收数据。  
145:              			同步模式: 任意值。
146:              		Bit2 FERR: 帧错误位。  
147:              			1= 帧错误（可通过读RCREG寄存器更新并接收下一个有效字节）；  
148:              			0= 没有帧错误。 
149:              		Bit1 OERR: 溢出错误位。  
150:              			1= 溢出错误（可通过清零CREN位清零）；  
151:              			0= 没有溢出错误。 
152:              		Bit0 RX9D: 接收到数据的第9位。 此位可以是地址/数据位或奇偶校验位，必须由用户固件计算得到
153:              	*********************************************************************************/
154:              	
155:              	RCSTA0 =  0B10010000;		//使能串口，使能接收
  003C    3090    LDIA	0x90
  003D    0099    LD	0x19,A
156:              	SPBRG0 =  51;        		 //波特率9600，目标波特率=FOSC/16([SPBRG]+1)
  003E    3033    LDIA	0x33
  003F    009A    LD	0x1A,A
157:              	
158:              	PEIE =1;
  0040    170B    SETB	0xB,6
159:              	RC0IE =1;
  0041    1303    CLRB	0x3,6
  0042    178E    SETB	0xE,7
160:              	GIE =1;
  0043    178B    SETB	0xB,7
  0044    0008    RET
161:              
162:              }
163:              
164:              /***********************************************
165:              函数名称：UART_Isr
166:              函数功能：UART中断服务
167:              入口参数：无
168:              出口参数：无
169:              备注：
170:              ************************************************/
171:              void interrupt UART_Isr()
172:              {
173:              	static unsigned char RxNum=0,TEMP;
174:              	
175:              	if(RC0IF==1)
  0066    1283    CLRB	0x3,5
  0067    1303    CLRB	0x3,6
  0068    1F8D    SNZB	0xD,7
  0069    287E    JP	0x7E
176:              	{
177:              		RC0IF = 0;
  006A    138D    CLRB	0xD,7
178:              	    
179:              		if(RXOK_f==0)	
  006B    1874    SZB	0x74,0
  006C    287C    JP	0x7C
180:              		{
181:              			RxTable[RxNum] = RCREG0;
  006D    0875    LD	A,0x75
  006E    3E20    ADDIA	0x20
  006F    0084    LD	0x4,A
  0070    1703    SETB	0x3,6
  0071    081C    LD	A,0x1C
  0072    1383    CLRB	0x3,7
  0073    0080    LD	0x0,A
  0074    300A    LDIA	0xA
182:              			RxNum++;
  0075    0AF5    INCR	0x75
183:              			if(RxNum > 9)
  0076    0275    SUBA	0x75
  0077    1C03    SNZB	0x3,0
  0078    287E    JP	0x7E
184:              			{
185:              				RxNum =0;
  0079    01F5    CLR	0x75
186:              				RXOK_f =1;
  007A    1474    SETB	0x74,0
  007B    287E    JP	0x7E
187:              			}
188:              		}
189:              		else
190:              		TEMP =  RCREG0;
  007C    1703    SETB	0x3,6
  007D    081C    LD	A,0x1C
  007E    0872    LD	A,0x72
  007F    008A    LD	0xA,A
  0080    0871    LD	A,0x71
  0081    0084    LD	0x4,A
  0082    0E70    SWAPA	0x70
  0083    0083    LD	0x3,A
  0084    0EFE    SWAPR	0x7E
  0085    0E7E    SWAPA	0x7E
  0086    0009    RETI
191:              		
192:              	}
193:              }
