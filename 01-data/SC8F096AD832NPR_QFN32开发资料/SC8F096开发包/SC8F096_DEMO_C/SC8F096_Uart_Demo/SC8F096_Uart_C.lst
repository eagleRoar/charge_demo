16:               /***********************************************************
17:               函数名称：DelayXms
18:               函数功能：毫秒级非精准延时
19:               入口参数：x - 延时时间
20:               出口参数：
21:               备    注：
22:               ***********************************************************/
23:               void DelayXms(unsigned char x)
24:               {
25:               	unsigned char i,j;
26:               	for(i=x;i>0;i--)
27:               		for(j=153;j>0;j--);
28:               }
29:               
