  0045    120A    CLRB	0xA,4
  0046    118A    CLRB	0xA,3
  0047    2023    CALL	0x23
37:               	
38:               	TXREG0 = 0x55;
  004A    3055    LDIA	0x55
  004B    1703    SETB	0x3,6
  004C    009B    LD	0x1B,A
39:               
40:               	while(TRMT0==0);
  004D    1C98    SNZB	0x18,1
  004E    284D    JP	0x4D
41:               	 TXREG0 =0xaa;
  004F    30AA    LDIA	0xAA
  0050    009B    LD	0x1B,A
42:               
43:               	while(TRMT0 == 0);
  0051    1C98    SNZB	0x18,1
  0052    2851    JP	0x51
44:               	
45:               	while(1)
46:               	{
47:                
48:               		
49:               		if(RXOK_f==1)
  0053    1C74    SNZB	0x74,0
  0054    2853    JP	0x53
50:               		{
51:               			for(i=0;i<10;i++)
  0055    01F3    CLR	0x73
52:               			{
53:               					
54:               				TXREG0 =RxTable[i];
  0056    0873    LD	A,0x73
  0057    3E20    ADDIA	0x20
  0058    0084    LD	0x4,A
  0059    1383    CLRB	0x3,7
  005A    0800    LD	A,0x0
  005B    1703    SETB	0x3,6
  005C    009B    LD	0x1B,A
55:               
56:               				while(TRMT0 == 0);
  005D    1C98    SNZB	0x18,1
  005E    285D    JP	0x5D
  005F    300A    LDIA	0xA
  0060    0AF3    INCR	0x73
  0061    0273    SUBA	0x73
  0062    1C03    SNZB	0x3,0
  0063    2856    JP	0x56
57:               			}
58:               
59:               			RXOK_f = 0;
  0064    1074    CLRB	0x74,0
  0065    2853    JP	0x53
60:               		}
61:               
62:               	}
