---- H:\MyDownloads\说明书&测试报告\开发包\SC8F096开发包\SC8F096_DEMO_C\SC8F096_Timer_Demo\SC8P096_Timer0_C.c ----------------------------------------------------------------------
1:                /*-------------------------------------------
2:                
3:                程序名称：Timer0定时中断程序
4:                日期版本：2024/09/14 <V1.0>
5:                
6:                备注：   
7:                
8:                *本程序由 &应用支持部& 编写整理
9:                -------------------------------------------*/
10:               #include <sc.h>					//芯片头文件，会根据工程选项自动寻找对应型号头文件
11:               
12:               void main(void)
13:               {
14:               	asm("nop");
15:               	asm("clrwdt");
16:               	OSCCON = 0x72;				//16MHZ,内部振荡器用作系统时钟,CONFIG关闭WDT时软件可以控制WDT开关
  0015    3072    LDIA	0x72
  0016    1283    CLRB	0x3,5
  0017    1303    CLRB	0x3,6
  0018    0094    LD	0x14,A
17:               	OPTION_REG = 0x00;			//配置TIMER0时间，00为2分频
  0019    0181    CLR	0x1
  001A    0064    CLRWDT
18:               	asm("clrwdt");
19:               	/*********************************************************************
20:               	预分频器控制寄存器 OPTION_REG（01H）
21:               	Bit7  未用 
22:               	Bit6  INTEDG:  触发中断的边沿选择位
23:               		1=  INT 引脚上升沿触发中断
24:               		0=  INT 引脚下降沿触发中断
25:               	Bit5  T0CS:  TIMER0 时钟源选择位
26:               		0=  内部指令周期时钟（FSYS /4）
27:               		1=	T0CKI 引脚上的跳变沿
28:               	Bit4  T0SE:	TIMER0 时钟源边沿选择位。
29:               		0=	在 T0CKI 引脚信号从低电平跳变到高电平时递增
30:               		1=	在 T0CKI 引脚信号从高电平跳变到低电平时递增
31:               	Bit3  PSA: 预分频器分配位
32:               		0=	预分频器分配给 TIMER0 模块
33:               		1=	预分频器分配给 WDT
34:               	Bit2~Bit0  PS2~PS0:  预分配参数配置位
35:               		PS2  PS1  PS0  TMR0分频比  WDT 分频比 
36:               		0    0    0  	1:2  		1:1 
37:               		0  	 0	  1		1:4			1:2 
38:               		0	 1	  0		1:8			1:4 
39:               		0	 1	  1		1:16		1:8 
40:               		1  	 0	  0		1:32		1:16 
41:               		1	 0	  1		1:64		1:32 
42:               		1	 1	  0		1:128		1:64 
43:               		1	 1	  1		1:256		1:128 
44:               	*********************************************************************/
45:               	
46:               	
47:               	WPUA = 0B00000000;
  001B    1683    SETB	0x3,5
  001C    1303    CLRB	0x3,6
  001D    0188    CLR	0x8
48:               	WPDA = 0B00000000;
  001E    0187    CLR	0x7
49:               	
50:               	IOCA = 0B00000000;
  001F    0189    CLR	0x9
51:               	TRISA = 0B00000000;
  0020    0185    CLR	0x5
52:               	
53:               	WPUB = 0B00000000;
  0021    1283    CLRB	0x3,5
  0022    0188    CLR	0x8
54:               	WPDB = 0B00000000;
  0023    0187    CLR	0x7
55:               
56:               	IOCB = 0B00000000;
  0024    0189    CLR	0x9
57:               	TRISB = 0B00000000;
  0025    0185    CLR	0x5
58:               	
59:               	
60:               	TMR0 = 6;					//设定Timer初始值，计时时间为（256-6）*4*2/16M=125uS
  0026    3006    LDIA	0x6
  0027    1683    SETB	0x3,5
  0028    0081    LD	0x1,A
61:               	T0IF = 0;
  0029    110B    CLRB	0xB,2
62:               	T0IE = 1;					//使能Timer0溢出中断
  002A    168B    SETB	0xB,5
63:               	
64:               	GIE = 1;					//开启总中断
  002B    178B    SETB	0xB,7
65:               	
66:               	while(1)
  002C    0064    CLRWDT
  002D    282C    JP	0x2C
67:               	{
68:               		asm("clrwdt");
69:               	}
70:               }
71:               /***********************************************
72:               函数名称：Timer0_Isr
73:               函数功能：中断服务
74:               入口参数：无
75:               出口参数：无
76:               备注：
77:               ************************************************/
78:               void interrupt Timer0_Isr(void)
79:               {
80:               	if(T0IF)
  002E    1D0B    SNZB	0xB,2
  002F    2838    JP	0x38
81:               	{
82:               		TMR0 += 6;			//TMR0不能自动赋值，操作TMR0的时候,TIME是不计数的
  0030    3006    LDIA	0x6
  0031    1683    SETB	0x3,5
  0032    1303    CLRB	0x3,6
  0033    0781    ADDR	0x1
83:               		T0IF = 0;
  0034    110B    CLRB	0xB,2
84:               		
85:               		PORTB ^= 0XFF;
  0035    30FF    LDIA	0xFF
  0036    1283    CLRB	0x3,5
  0037    0686    XORR	0x6
  0038    0871    LD	A,0x71
  0039    008A    LD	0xA,A
  003A    0E70    SWAPA	0x70
  003B    0083    LD	0x3,A
  003C    0EFE    SWAPR	0x7E
  003D    0E7E    SWAPA	0x7E
  003E    0009    RETI
86:               	}
87:               }
88:               
89:               
