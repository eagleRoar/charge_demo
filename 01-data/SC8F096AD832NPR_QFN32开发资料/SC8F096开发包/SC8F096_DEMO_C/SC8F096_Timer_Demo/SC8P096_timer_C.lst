  0000    120A    CLRB	0xA,4
  0001    118A    CLRB	0xA,3
  0002    280C    JP	0xC
  000C    120A    CLRB	0xA,4
  000D    118A    CLRB	0xA,3
  000E    280F    JP	0xF
---- start_initialization ------------------------------------------------------------------
---- interrupt_function_enter ----------------------------------------------------------
  0004    00FE    LD	0x7E,A
  0005    0E03    SWAPA	0x3
  0006    00F0    LD	0x70,A
  0007    080A    LD	A,0xA
  0008    00F1    LD	0x71,A
  0009    120A    CLRB	0xA,4
  000A    118A    CLRB	0xA,3
  000B    282E    JP	0x2E
---- common_function ------------------------------------------------------------------
  000F    0183    CLR	0x3
  0010    120A    CLRB	0xA,4
  0011    118A    CLRB	0xA,3
  0012    2813    JP	0x13
  0013    0000    NOP
  0014    0064    CLRWDT
