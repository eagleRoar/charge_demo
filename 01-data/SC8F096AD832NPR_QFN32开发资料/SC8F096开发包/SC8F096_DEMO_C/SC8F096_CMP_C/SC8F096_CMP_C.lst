---- H:\MyDownloads\说明书&测试报告\开发包\SC8F096AD开发包\SC8F096_DEMO_C\SC8F096_CMP_C\SC8F096_CMP_C.c ----------------------------------------------------------------------
1:                /*-------------------------------------------
2:                
3:                程序名称：比较器设置示例程序
4:                日期版本：2024/09/18 <V1.0>
5:                
6:                      
7:                *本程序由 &应用支持部& 编写整理
8:                -------------------------------------------*/
9:                
10:               
11:               #include <sc.h>						//芯片头文件，会根据工程选项自动寻找对应型号头文件
12:               
13:               
14:               void main(void)
  0013    0000    NOP
  0014    0064    CLRWDT
15:               {
16:               	asm("nop");
17:               	asm("clrwdt");
18:               	
19:               	OSCCON = 0x72;					//16MHZ,内部振荡器用作系统时钟,CONFIG关闭WDT时必需软件打开WDT
  0015    3072    LDIA	0x72
  0016    1283    CLRB	0x3,5
  0017    1303    CLRB	0x3,6
  0018    0094    LD	0x14,A
20:               	OPTION_REG = 0x09;				//配置WDT时间，09为2分频，即16*2=32ms溢出
  0019    3009    LDIA	0x9
  001A    0081    LD	0x1,A
21:               	
22:               	
23:               	WPUB = 0B00000000;
  001B    0188    CLR	0x8
24:               	WPDB = 0B00000000;
  001C    0187    CLR	0x7
25:               	IOCB = 0B00000000;
  001D    0189    CLR	0x9
26:               	
27:               	TRISA = 0B00000000;	
  001E    1683    SETB	0x3,5
  001F    0185    CLR	0x5
28:               	TRISB = 0B00000000;
  0020    1283    CLRB	0x3,5
  0021    0185    CLR	0x5
29:               	
30:               	PORTA = 0B00000000;	
  0022    1683    SETB	0x3,5
  0023    0186    CLR	0x6
31:               	PORTB = 0B00000000;
  0024    1283    CLRB	0x3,5
  0025    0186    CLR	0x6
32:               	
33:               	/***************************************************
34:               	比较器控制寄存器 CMPxCON0
35:               	Bit7  CMPxEN:  CMP使能位
36:               		1=  使能CMP
37:               		0=  禁止CMP
38:               	Bit6  CMPxPS:  CMP正端输入选择位
39:               		1=  CMP+端口电压
40:               		0=  VDD经过内部电阻分压后的电压
41:               	Bit5~Bit3  CMPxNS<2:0>:  CMP负端输入选择位
42:               		000=  CMP0- 端口电压
43:               		001=  CMP1- 端口电压
44:               		010=  CMP2-端口电压
45:               		011=  CMP3-端口电压
46:               		100=  VDD经过内部电阻分压后的电压
47:               		101=  BG
48:               		11x=  BG
49:               	Bit2  CMPxNV:  CMPO端口输出取反控制位
50:               		1=  CMPOUT在CMPO端口取反输出
51:               		0=  CMPOUT在CMPO端口正常输出
52:               	Bit1  CMPxOUT:  CMP结果位
53:               	Bit0  CMPxOEN:  CMPO端口输出使能位
54:               		1=  使能CMPO端口输出CMPOUT
55:               		0=  禁止CMPO端口输出CMPOUT
56:               	*****************************************************/
57:               	CMP1CON0 = 0B00111000;			//配置比较器1正端为VDD分压，负端为BG1.2V，禁止比较器输出
  0026    3038    LDIA	0x38
  0027    008F    LD	0xF,A
58:               	
59:               	CMP2CON0 = 0B00111001;			//配置比较器2正端为VDD分压，负端为BG1.2V，使能比较器输出
  0028    3039    LDIA	0x39
  0029    1683    SETB	0x3,5
  002A    009A    LD	0x1A,A
60:               	/***************************************
61:               	比较器控制寄存器 CMPxCON1(10H)
62:               	Bit7  CMPxIM:  CMP中断触发边沿选择
63:               		1=  CMP输出的下降沿触发中断
64:               		0=  CMP输出的上升沿触发中断
65:               	Bit6  ANx_EN:  模拟选择位，选择CMP+、CMPX-的模拟或数字功能
66:               		1=  模拟口
67:               		0=  数字口
68:               	Bit5  RBIASx_H:  具体用法参考比较器框图
69:               	Bit4  RBIASx_L:  具体用法参考比较器框图
70:               	Bit3~Bit0  LVDSx<3:0>:  内部电阻分压比选择位
71:               	****************************************************/
72:               	
73:               	CMP1CON1 = 0B10010111;			//	测试VDD电压低于3.6V中断，故为下降沿触发
  002B    3097    LDIA	0x97
  002C    1283    CLRB	0x3,5
  002D    0090    LD	0x10,A
74:               									//Bit5~0对应的电压值可参考芯片说明书
75:               	CMP2CON1 = 0B10000000;			//	测试VDD电压低于4.27V中断，故为下降沿触发
  002E    3080    LDIA	0x80
  002F    1683    SETB	0x3,5
  0030    009F    LD	0x1F,A
76:               	
77:               	INTCON = 0XC0;					//允许总中断及外设中断
  0031    30C0    LDIA	0xC0
  0032    008B    LD	0xB,A
78:               
79:               	CMP1EN = 1;						//比较器使能
  0033    1283    CLRB	0x3,5
  0034    178F    SETB	0xF,7
80:               	CMP1IF =0;						//清比较器中断标志位
  0035    128D    CLRB	0xD,5
81:               		
82:               	CMP2EN = 1;						//比较器使能
  0036    1683    SETB	0x3,5
  0037    179A    SETB	0x1A,7
83:               	CMP2IF =0;						//清比较器中断标志位
  0038    1283    CLRB	0x3,5
  0039    1703    SETB	0x3,6
  003A    128F    CLRB	0xF,5
84:               
85:               									//要先使能比较器再打开中断允许
86:               	PIE1 = 0X20;					//允许比较器1中断
  003B    3020    LDIA	0x20
  003C    1303    CLRB	0x3,6
  003D    008E    LD	0xE,A
87:               	PIE2 = 0X20;					//允许比较器2中断
  003E    1703    SETB	0x3,6
  003F    0090    LD	0x10,A
88:               	while(1)
  0040    0064    CLRWDT
  0041    2840    JP	0x40
89:               	{
90:               		asm("clrwdt");
91:               		
92:               						
93:               	}
94:               }
95:               
96:               /***********************************************
97:               函数名称：CMP_Isr
98:               函数功能：INT中断服务
99:               入口参数：无
100:              出口参数：无
101:              备注：
102:              ************************************************/
103:              void interrupt CMP_Isr()
104:              {
105:              	if(CMP1IF)
  0042    1283    CLRB	0x3,5
  0043    1303    CLRB	0x3,6
  0044    1E8D    SNZB	0xD,5
  0045    284A    JP	0x4A
106:              	{
107:              		CMP1IF = 0;			//清中断标志
  0046    128D    CLRB	0xD,5
108:              		
109:              		PORTA ^= 0X80;
  0047    3080    LDIA	0x80
  0048    1683    SETB	0x3,5
  0049    0686    XORR	0x6
110:              		
111:              	}
112:              	if(CMP2IF)
  004A    1283    CLRB	0x3,5
  004B    1703    SETB	0x3,6
  004C    1E8F    SNZB	0xF,5
  004D    2853    JP	0x53
113:              	{
114:              		CMP2IF = 0;			//清中断标志
  004E    128F    CLRB	0xF,5
115:              		PORTA ^= 0X40;
  004F    3040    LDIA	0x40
  0050    1683    SETB	0x3,5
  0051    1303    CLRB	0x3,6
  0052    0686    XORR	0x6
  0053    0871    LD	A,0x71
  0054    008A    LD	0xA,A
  0055    0E70    SWAPA	0x70
  0056    0083    LD	0x3,A
  0057    0EFE    SWAPR	0x7E
  0058    0E7E    SWAPA	0x7E
  0059    0009    RETI
116:              		
117:              	}
118:              }
