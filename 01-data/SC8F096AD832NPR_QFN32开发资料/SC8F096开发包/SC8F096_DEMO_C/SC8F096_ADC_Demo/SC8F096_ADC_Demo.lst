230:              			ШчКѓМЬГЬађВЛЙиБеADONЃЌдђВЛашвЊбгЪБ
231:              ***********************************************************/
232:              void AD_Init() 
233:              {
234:              	/*********** ADCON0 ****************************
235:              		Bit7~Bit6  ADCS<1:0>:  ADзЊЛЛЪБжгбЁдёЮЛЁЃ
236:              			00=  F HSI /16
237:              			01=  F HSI /32
238:              			10=  F HSI /64
239:              			11=  F HSI /128
240:              		Bit5~Bit2  CHS<3:0>:  ФЃФтЭЈЕРбЁдёЮЛЁЃгыADCON1МФДцЦїCHS4зщКЯCHS<3:0>
241:              			CHS<4:0>: 
242:              			00000=  AN0
243:              			00001=  AN1
244:              			00010=  AN2
245:              			00011=  AN3
246:              			00100=  AN4
247:              			00101=  AN5
248:              			Ё­ 
249:              			11100=  AN28
250:              			11101=  AN29
251:              			11110=  OPAЪфГі
252:              			11111=  1.2VЃЈЙЬЖЈВЮПМЕчбЙЃЉ
253:              			ЦфЫћ=  БЃСє
254:              		Bit1  GO/DONE: ADзЊЛЛзДЬЌЮЛЁЃ
255:              			1=  ADзЊЛЛе§дкНјааЁЃНЋИУЮЛжУ1ЦєЖЏADзЊЛЛЁЃЕБADзЊЛЛЭъГЩвдКѓЃЌИУЮЛгЩгВМўздЖЏЧхСуЁЃ
256:              				ЕБGO/DONEЮЛДг1Бф0ЛђADIFДг0Бф1ЪБЃЌашжСЩйЕШД§СНИіTADЪБМфЃЌВХФмдйДЮЦєЖЏADзЊЛЛЁЃ
257:              			0=  ADзЊЛЛЭъГЩ/ЛђВЛдкНјаажаЁЃ
258:              		Bit0  ADON:  ADCЪЙФмЮЛЁЃ
259:              			1=  ЪЙФмADCЃЛ
260:              			0=  НћжЙADCЃЌВЛЯћКФЙЄзїЕчСїЁЃ
261:              	*********************************************/
262:              	ADCON0 = 0X41;		//ADONПЊЦєЃЌADВЩбљЪБМфбЁЮЊFSYS/32
  02D2    3041    LDIA	0x41
  02D3    1683    SETB	0x3,5
  02D4    0095    LD	0x15,A
263:              	
264:              	/*********** ADCON1 ****************************
265:              		Bit7  ADFM:  ADзЊЛЛНсЙћИёЪНбЁдёЮЛЃЛ
266:              			1=  гвЖдЦыЃЛ
267:              			0=  зѓЖдЦыЁЃ
268:              		Bit6  CHS4:  ЭЈЕРбЁдёЮЛ
269:              		Bit5~Bit3  ЮДгУ 
270:              		Bit2  LDO_EN:  ФкВПВЮПМЕчбЙЪЙФмЮЛЁЃ
271:              			1=  ЪЙФмADCФкВПLDOВЮПМЕчбЙЃЛ
272:              				ЕБбЁдёФкВПLDOзїВЮПМЕчбЙЪБЃЌADCзюДѓгааЇОЋЖШЮЊ8ЮЛЁЃ
273:              			0=  VDDзїЮЊADCВЮПМЕчбЙЁЃ
274:              		Bit1~Bit0  LDO_SEL<1:0>:  ВЮПМЕчбЙбЁдёЮЛ
275:              			0X=  2.0V
276:              			10=  2.4V
277:              			11=  3.0V
278:              	*********************************************/
279:              	ADCON1 = 0;
  02D5    0196    CLR	0x16
  02D6    0008    RET
280:              }
