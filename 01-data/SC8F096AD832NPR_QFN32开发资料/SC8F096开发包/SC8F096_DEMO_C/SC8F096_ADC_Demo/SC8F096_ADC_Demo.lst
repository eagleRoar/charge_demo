15:               float
16:               __lwtoft(unsigned int c)
17:               {
18:               	float	f1;
19:               	
20:               	if(c == 0)
21:               		return 0.0;
22:               	f1_as_mant1 = c;
23:               	__ftpack(&f1_as_mant1, 127+15);
24:               	return f1;
25:               }
26:               #else
27:               float
28:               __lwtoft(unsigned int c)
  010D    0820    LD	A,0x20
  010E    00F2    LD	0x72,A
  010F    0821    LD	A,0x21
  0110    00F3    LD	0x73,A
  0111    308E    LDIA	0x8E
