89:               /***********************************************
90:               函数名称：Memory_Write
91:               函数功能：写数据/程序寄存器
92:               入口参数：Addr - 写入地址
93:                         Value - 写入数值
94:               出口参数：无
95:               备注：
96:               ************************************************/
97:               void Memory_Write(unsigned char Addr,unsigned int Value)
98:               {
99:               											//将要写入的地址放入EEADDR寄存器
100:              	EEADR = Addr;
  0769    1683    SETB	0x3,5
  076A    1303    CLRB	0x3,6
  076B    0091    LD	0x11,A
101:              	EEPGD = 0;								//访问数据存储器
  076C    138D    CLRB	0xD,7
102:              											
103:              	EEDAT = (unsigned char)(Value & 0x00ff);				//将要写入的数据给EEPROM的数据寄存器
  076D    0876    LD	A,0x76
  076E    008F    LD	0xF,A
104:              	EEDATH = (Value & 0xff00)>>8;
  076F    0877    LD	A,0x77
  0770    0090    LD	0x10,A
105:              	
106:              	WREN = 1;								//允许写周期
  0771    150D    SETB	0xD,2
107:              	GIE = 0;								//关闭中断
  0772    138B    CLRB	0xB,7
108:              	
109:              	while(GIE) GIE = 0;						//确保中断已关闭
  0773    1B8B    SZB	0xB,7
  0774    2F72    JP	0x772
110:              	
111:              	
112:              	EECON2 = 0x55;							//给EECON2写入0x55
  0775    3055    LDIA	0x55
  0776    1683    SETB	0x3,5
  0777    1303    CLRB	0x3,6
  0778    008E    LD	0xE,A
113:              	EECON2 = 0xaa;							//给EECON2写入0xaa
  0779    30AA    LDIA	0xAA
  077A    008E    LD	0xE,A
114:              	WR = 1;									//启动写周期
  077B    148D    SETB	0xD,1
  077C    0000    NOP
  077D    0000    NOP
  077E    0064    CLRWDT
115:              	asm("nop");								//写EEDATA的时候，CPU 会停止工作，写完才执行这条语句
116:              	asm("nop");
117:              	asm("clrwdt");
118:              		
119:              	WREN = 0;								//禁止写入
  077F    1683    SETB	0x3,5
  0780    1303    CLRB	0x3,6
  0781    110D    CLRB	0xD,2
120:              	GIE = 1;								//开启中断							
  0782    178B    SETB	0xB,7
  0783    0008    RET
121:              	
122:              }
