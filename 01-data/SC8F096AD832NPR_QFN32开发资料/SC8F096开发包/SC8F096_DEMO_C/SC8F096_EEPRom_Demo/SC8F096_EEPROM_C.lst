  079D    0092    LD	0x12,A
159:              	
160:              	EEPGD = 1;						//访问程序存储器
  079E    178D    SETB	0xD,7
161:              	
162:              	RD = 1;							//允许读操作
  079F    140D    SETB	0xD,0
  07A0    0000    NOP
  07A1    0000    NOP
163:              	asm("nop");						//读取数据必须加两个nop
164:              	asm("nop");
165:              	
166:              	read_rom_data = EEDAT;
  07A2    1683    SETB	0x3,5
  07A3    1303    CLRB	0x3,6
  07A4    080F    LD	A,0xF
  07A5    00F4    LD	0x74,A
  07A6    0008    RET
167:              	
168:              }
