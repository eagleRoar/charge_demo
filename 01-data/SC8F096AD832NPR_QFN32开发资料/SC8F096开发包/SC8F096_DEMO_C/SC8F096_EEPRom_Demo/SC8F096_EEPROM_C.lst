131:              ************************************************/
132:              void Memory_Read(unsigned char Addr)
133:              {
134:              									//将要写入的地址放入EEADDR寄存器
135:              	EEADR = Addr;
  0785    0091    LD	0x11,A
136:              	EEPGD = 0;						//访问数据存储器
  0786    138D    CLRB	0xD,7
137:              	
138:              	RD = 1;							//允许读操作
  0787    140D    SETB	0xD,0
  0788    0000    NOP
  0789    0000    NOP
139:              	asm("nop");						//读取数据必须加两个nop
140:              	asm("nop");
141:              	
142:              	read_data = EEDAT;
  078A    1683    SETB	0x3,5
  078B    1303    CLRB	0x3,6
  078C    080F    LD	A,0xF
  078D    00F0    LD	0x70,A
  078E    01F1    CLR	0x71
143:              	read_data = read_data | (unsigned int)(EEDATH<<8);
  078F    0810    LD	A,0x10
  0790    00F6    LD	0x76,A
  0791    01F7    CLR	0x77
  0792    00F7    LD	0x77,A
  0793    01F6    CLR	0x76
  0794    0876    LD	A,0x76
  0795    04F0    ORR	0x70
  0796    0877    LD	A,0x77
  0797    04F1    ORR	0x71
  0798    0008    RET
144:              	
145:              }
