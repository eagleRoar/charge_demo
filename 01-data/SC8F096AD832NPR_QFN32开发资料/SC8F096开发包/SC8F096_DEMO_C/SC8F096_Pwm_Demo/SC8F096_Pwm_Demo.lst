---- H:\MyDownloads\说明书&测试报告\开发包\SC8F096AD开发包\SC8F096_DEMO_C\SC8F096_Pwm_Demo\SC8F096_Pwm_Demo.c ----------------------------------------------------------------------
1:                
2:                //CCP1 PWM模式参考程序
3:                #include <sc.h>           		//调用单片机的头文件
4:                
5:                void Init_System();
6:                
7:                	
8:                void main(void)            		//主函数,单片机开机后就是从这个函数开始运行
9:                {
10:               	unsigned int delaycnt = 0;
  07BE    01F0    CLR	0x70
  07BF    01F1    CLR	0x71
11:               	unsigned char pwmbuf = 0X1F;
  07C0    00F2    LD	0x72,A
12:               
13:               	Init_System();
  07C1    120A    CLRB	0xA,4
  07C2    118A    CLRB	0xA,3
  07C3    27A9    CALL	0x7A9
14:               	
15:               								//以下是对PWM功能初始化
16:               		/************PWMCON1定义**************************
17:               		Bit7~6 PWMIO_SEL[1:0]: PWM IO选择。
18:               			11= PWM分配在A组，PWM0-RA0,PWM1-RA1,PWM2-RA2,PWM3-RA3,PWM4-RA4
19:               			10= PWM分配在B组，PWM0-RA0,PWM1-RA1,PWM2-RA2,PWM3-RB2,PWM4-RB1
20:               			01= PWM分配在C组，PWM0-RA5,PWM1-RB7,PWM2-RB6,PWM3-RB5,PWM4-RB4
21:               			00= PWM分配在D组，PWM0-RB0,PWM1-RB1,PWM2-RB3,PWM3-RB4,PWM4-RB2
22:               		Bit5 PWM2DTEN: PWM2死区使能位。
23:               			1= 使能PWM2死区功能，PWM2和PWM3组成一对互补输出。
24:               			0= 禁止PWM2死区功能。
25:               		Bit4 PWM0DTEN: PWM0死区使能位。
26:               			1= 使能PWM0死区功能，PWM0和PWM1组成一对互补输出。
27:               			0= 禁止PWM0死区功能。
28:               		Bit3~Bit2 未用。
29:               		Bit1~Bit0 DT_DIV[1:0] 死区时钟源分频。
30:               			11= FOSC/8
31:               			10= FOSC/4
32:               			01= FOSC/2
33:               			00= FOSC/1
34:               	**********************************************************************/
35:               		PWMCON1 = 0B11010010;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
  07C6    30D2    LDIA	0xD2
  07C7    0096    LD	0x16,A
36:               		
37:               		TRISA	= 0B00011111;	//选择的PA0~PA4口设为输入
  07C8    301F    LDIA	0x1F
  07C9    1683    SETB	0x3,5
  07CA    0085    LD	0x5,A
38:               		PWMTH = 0X0C;			//周期选择为0FF，则周期为（255+1）*1/16M，周期的时钟分频在PWMCON0选择
  07CB    300C    LDIA	0xC
  07CC    1283    CLRB	0x3,5
  07CD    0098    LD	0x18,A
39:               								//PWM4周期选择为03FF，需先写高位
40:               		PWMTL = 0XFF;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
  07CE    30FF    LDIA	0xFF
  07CF    0097    LD	0x17,A
41:               		PWMT4L = 0XFF;
  07D0    009C    LD	0x1C,A
42:               		
43:               		PWMDH = 0;				//配置PWM0~3的占空比，该值不能超过周期，否者为100%输出
  07D1    019E    CLR	0x1E
44:               								//，需先写高位
45:               		PWMD0L = 0X1F;			//脉冲宽度 = (PWMDx[9:0]+1)*TOSC*(CLKDIV 分频值)
  07D2    301F    LDIA	0x1F
  07D3    0099    LD	0x19,A
46:               								//必须注意根据公式，即使占空比设为0仍有脉冲输出，如要输出低电平
47:               								//需要关闭PWMEN，然后设为输出低
48:               		PWMD1L = 0X7F;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  07D4    307F    LDIA	0x7F
  07D5    009A    LD	0x1A,A
49:               		
50:               		PWM01DT = 0X03;			//死区设为2uS，计算为（3+1）*1/8M*4
  07D6    3003    LDIA	0x3
  07D7    009F    LD	0x1F,A
51:               								//死区1的占空比以PWM0设置的占空比为基准
52:               				
53:               		PWMD2L = 0X3F;        	//PWM2 占空比低位寄存器   该值不能超过周期，否者为100%输出
  07D8    303F    LDIA	0x3F
  07D9    1683    SETB	0x3,5
  07DA    009B    LD	0x1B,A
54:               		PWMD3L = 0X7F;			//PWM3 占空比低位寄存器 ，互补以PWM0占空比为准
  07DB    307F    LDIA	0x7F
  07DC    009C    LD	0x1C,A
55:               		
56:               		PWMD4L = 0X1F;			//PWM4 占空比低位寄存器,PWM4占空比高位在PWMTH的Bit4~5 
  07DD    301F    LDIA	0x1F
  07DE    1283    CLRB	0x3,5
  07DF    009B    LD	0x1B,A
57:               				
58:               	/***************PWMCON0*************************************
59:               		Bit7~Bit5 CLKDIV[2:0]: PWM时钟分频。
60:               			111= FOSC/128
61:               			110= FOSC/64
62:               			101= FOSC/32
63:               			100= FOSC/16
64:               			011= FOSC/8
65:               			010= FOSC/4
66:               			001= FOSC/2
67:               			000= FOSC/1
68:               		Bit4~Bit0 PWMxEN: PWMx使能位。
69:               			1= 使能PWMx。
70:               			0= 禁止PWMx。
71:               	******************************************************************/
72:               		PWMCON0 = 0X1F;			//打开PWM0~PWM4,分频比为1
  07E0    0095    LD	0x15,A
73:               		PWMCON2 =0X10;			//PWM4输出反向
  07E1    3010    LDIA	0x10
  07E2    009D    LD	0x1D,A
74:               		TRISA = 0;				//对应的口线设为输出
  07E3    1683    SETB	0x3,5
  07E4    0185    CLR	0x5
75:               		
76:                   while(1)					//死循环,单片机初始化后,将一直运行这个死循环
  07E5    0064    CLRWDT
77:                   {
78:               		asm("clrwdt");
79:               		if(++delaycnt > 5000)	//延时20000个软件周期，非精确定时
  07E6    0AF0    INCR	0x70
  07E7    1903    SZB	0x3,2
  07E8    0AF1    INCR	0x71
  07E9    3013    LDIA	0x13
  07EA    0271    SUBA	0x71
  07EB    3089    LDIA	0x89
  07EC    1903    SZB	0x3,2
  07ED    0270    SUBA	0x70
  07EE    1C03    SNZB	0x3,0
  07EF    2FE5    JP	0x7E5
80:                  		{
81:                  			delaycnt = 0;       //清零以备下次重新计数
  07F0    01F0    CLR	0x70
  07F1    01F1    CLR	0x71
82:                  			if(++pwmbuf > 0xfe)	//占空比加一
  07F2    0AF2    INCR	0x72
  07F3    0F72    SZINCA	0x72
  07F4    2FF7    JP	0x7F7
83:                  			{
84:                  				pwmbuf = 0x01f;
  07F5    301F    LDIA	0x1F
  07F6    00F2    LD	0x72,A
85:                  			}
86:               			PWMD0L = pwmbuf;	//写入占空比
  07F7    0872    LD	A,0x72
  07F8    1283    CLRB	0x3,5
  07F9    1303    CLRB	0x3,6
  07FA    0099    LD	0x19,A
  07FB    2FE5    JP	0x7E5
87:                  		}
88:                   }
89:               }
90:               
91:               
92:               /***********************************************
93:               函数名称：Init_System
94:               函数功能：系统初始化
95:               入口参数：无
96:               出口参数：无
97:               备注：
98:               ************************************************/
99:               void Init_System()
100:              {
101:              	asm("nop");
102:              	asm("clrwdt");
103:              	INTCON = 0;					//系统初始化
  07AB    018B    CLR	0xB
104:              	OSCCON = 0X72;				//配置振荡为8M
  07AC    3072    LDIA	0x72
  07AD    1283    CLRB	0x3,5
  07AE    1303    CLRB	0x3,6
  07AF    0094    LD	0x14,A
105:              	OPTION_REG = 0;
  07B0    0181    CLR	0x1
  07B1    0064    CLRWDT
106:              	asm("clrwdt");
107:              	
108:              	TRISA = 0B00011111;			//初始化IO状态
  07B2    301F    LDIA	0x1F
  07B3    1683    SETB	0x3,5
  07B4    1303    CLRB	0x3,6
  07B5    0085    LD	0x5,A
109:              	TRISB = 0B00000000;
  07B6    1283    CLRB	0x3,5
  07B7    0185    CLR	0x5
110:              
111:              	PORTA = 0B00000000;
  07B8    1683    SETB	0x3,5
  07B9    0186    CLR	0x6
112:              	PORTB = 0B00000000;			//初始化输出
  07BA    1283    CLRB	0x3,5
  07BB    0186    CLR	0x6
  07BC    0008    RET
113:              
114:              }
