  07C8    0879    LD	A,0x79
  07C9    3E01    ADDIA	0x1
  07CA    1683    SETB	0x3,5
  07CB    0093    LD	0x13,A
119:              	while(IICIF==0);
  07CC    1283    CLRB	0x3,5
  07CD    1E0F    SNZB	0xF,4
  07CE    2FCC    JP	0x7CC
120:              	IICIF = 0;    
  07CF    120F    CLRB	0xF,4
121:              	RCEN = 1;           //开始接收数据
  07D0    1683    SETB	0x3,5
  07D1    1591    SETB	0x11,3
122:              	while(IICIF==0);
  07D2    1283    CLRB	0x3,5
  07D3    1E0F    SNZB	0xF,4
  07D4    2FD2    JP	0x7D2
123:              	IICIF = 0;
  07D5    120F    CLRB	0xF,4
  07D6    1683    SETB	0x3,5
  07D7    0813    LD	A,0x13
124:              	ReadData = IICBUF;  //读取接收的数据
125:              	
