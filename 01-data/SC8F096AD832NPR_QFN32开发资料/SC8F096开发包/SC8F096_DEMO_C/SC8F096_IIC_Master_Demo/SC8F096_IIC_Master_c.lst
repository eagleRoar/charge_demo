152:              void main()
153:              {
154:              	Init_System();
  0785    120A    CLRB	0xA,4
  0786    118A    CLRB	0xA,3
  0787    274F    CALL	0x74F
155:              	TRISA |=  0B00000011;  //RA0 RA1输入态，做IIC 引脚时为开漏，需要外接上拉电阻
  078A    3003    LDIA	0x3
  078B    1683    SETB	0x3,5
  078C    0485    ORR	0x5
156:              	
157:              	/********** IICCON ***********************************
158:              	Bit7  IICWCOL:  写冲突检测位。
159:              		主控模式:  
160:              			1= 在IIC不满足开始发送数据的条件下，试图对IICBUF寄存器进行写操作。
161:              			0= 未发生冲突。
162:              		从动模式: 
163:              			1= 正在发送前一个字时，又对IICBUF寄存器进行写操作（必须由软件清零）。
164:              			0= 未发生冲突。
165:              	Bit6  IICOV:  接收溢出指示位。(仅在从动接收模式下有限)
166:              			1=  IICBUF寄存器仍保持前一数据时，又接收到一个新的字节。在发送模式下IICOV
167:              				位可为任意值（该位必须由软件清零）。
168:              			0=  没有溢出。
169:              	Bit5  IICEN:  IIC使能位（必须正确配置这些引脚为输入）。
170:              			1=  使能IIC并将SDA和SCL引脚配置为串行端口引脚。
171:              			0=  禁止IIC并将这些引脚配置为I/O端口引脚。
172:              	Bit4  IICCKP:  时钟极性选择位。
173:              		在IIC从动模式下:  SCK释放控制。
174:              			1 = 使能时钟。
175:              			0 = 保持时钟线为低电平（时钟延长）（用于确保数据建立时间）。
176:              		在IIC主控模式下:  在此模式下未使用。
177:              	Bit3~Bit2  IICTOS[1:0]:  IIC从动模式超时选择
178:              		00=  禁止IIC从动超时功能；
179:              		01=  使能IIC从动超时功能，超时时间为16ms，超时后复位IIC模块；
180:              		10=  使能IIC从动超时功能，超时时间为32ms，超时后复位IIC模块；
181:              		11=  使能IIC从动超时功能，超时时间为64ms，超时后复位IIC模块；
182:              	Bit1~Bit0  IICM<1:0>:  IIC模式选择位。
183:              		00=  IIC主控模式，时钟=  FCPU / (IICADD+4)；
184:              		01=  IIC从动模式，7位地址，不响应起始位和停止位中断；
185:              		10=  IIC从动模式，7位地址，并允许起始位和停止位中断；
186:              		11=  允许操作IICMSK寄存器
187:              	*************************************************/
188:              	IICCON =  0B00100000;  // IIC 使能  主动模式
  078D    3020    LDIA	0x20
  078E    1703    SETB	0x3,6
  078F    0090    LD	0x10,A
189:                  IICADD = 36;          // 100K 频率 = 16M /4/36+4
  0790    3024    LDIA	0x24
  0791    0094    LD	0x14,A
190:              	
191:              	while(1)
