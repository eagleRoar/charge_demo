  07A0    3080    LDIA	0x80
  07A1    00F7    LD	0x77,A
  07A2    30A0    LDIA	0xA0
  07A3    120A    CLRB	0xA,4
  07A4    118A    CLRB	0xA,3
  07A5    27AD    CALL	0x7AD
  07A8    00F6    LD	0x76,A
197:              		 RB5 = ~RB5;
  07A9    3020    LDIA	0x20
  07AA    1303    CLRB	0x3,6
  07AB    0686    XORR	0x6
  07AC    2F92    JP	0x792
