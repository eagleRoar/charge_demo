  07D8    1291    CLRB	0x11,5
127:              	ACKEN = 1;			//发送应答位
  07D9    1611    SETB	0x11,4
128:              	
129:              	while(IICIF==0);
  07DA    1283    CLRB	0x3,5
  07DB    1E0F    SNZB	0xF,4
  07DC    2FDA    JP	0x7DA
130:              	IICIF = 0;
  07DD    120F    CLRB	0xF,4
131:              	
132:              	RCEN = 1;           //开始接收第二个数据
  07DE    1683    SETB	0x3,5
  07DF    1591    SETB	0x11,3
133:              	while(IICIF==0);
  07E0    1283    CLRB	0x3,5
  07E1    1E0F    SNZB	0xF,4
  07E2    2FE0    JP	0x7E0
134:              	IICIF = 0;
  07E3    120F    CLRB	0xF,4
135:              	ReadData = IICBUF;  //读取接收的数据
  07E4    1683    SETB	0x3,5
  07E5    0813    LD	A,0x13
  07E6    00F8    LD	0x78,A
136:              	
137:              	ACKDT = 1;			//产生主机应答
  07E7    1691    SETB	0x11,5
