  07F2    0085    LD	0x5,A
145:              	TRISC = 0B00000000; 
  07F3    1703    SETB	0x3,6
  07F4    0185    CLR	0x5
146:              	TRISD = 0B00000000;
  07F5    0194    CLR	0x14
147:              
148:                 //PORTA = 0B00000000;         
149:              	PORTB = 0B00000000;			//初始化输出
  07F6    1303    CLRB	0x3,6
  07F7    0186    CLR	0x6
