53:               /***********************************************
54:               函数名称：Sleep_Mode
55:               函数功能：进入休眠模式
56:               入口参数：无
57:               出口参数：无
58:               备注：
59:               ************************************************/
60:               void Sleep_Mode()
61:               {
62:               	INTCON = 0;		
  078B    018B    CLR	0xB
63:               	
64:               	OPTION_REG = 0;
  078C    1283    CLRB	0x3,5
  078D    1303    CLRB	0x3,6
  078E    0181    CLR	0x1
65:               
66:               	TRISA = 0B00000001; 		//关闭所有输出，RA0口做唤醒输入
  078F    3001    LDIA	0x1
  0790    1683    SETB	0x3,5
  0791    0085    LD	0x5,A
67:               	PORTA = 0B00000000;
  0792    0186    CLR	0x6
68:               	WPUA  = 0B00000001;			//RA0 开上拉电阻
  0793    0088    LD	0x8,A
69:               	
70:               	TRISB = 0B00001000;			//关闭所有输出，RB3口做唤醒输入
  0794    3008    LDIA	0x8
  0795    1283    CLRB	0x3,5
  0796    0085    LD	0x5,A
71:               	PORTB = 0B00000000;
  0797    0186    CLR	0x6
72:               	WPUB  = 0B00001000;			//RB3 开上拉电阻
  0798    0088    LD	0x8,A
73:                  		
74:               	TRISC = 0B00000000;			//必须确保芯片的IO不能处于悬空状态
  0799    1703    SETB	0x3,6
  079A    0185    CLR	0x5
75:               	PORTC = 0B00000000;	
  079B    0186    CLR	0x6
76:               	
77:               	TRISD = 0B00000000;
  079C    0194    CLR	0x14
78:               	PORTD = 0B00000000;	
  079D    0187    CLR	0x7
79:               			
80:                  	ADCON0 = 0;					//关闭所有模块
  079E    1683    SETB	0x3,5
  079F    1303    CLRB	0x3,6
  07A0    0195    CLR	0x15
81:               	ADCON1 = 0;
  07A1    0196    CLR	0x16
82:               	CMP1CON0 = 0;
  07A2    1283    CLRB	0x3,5
  07A3    018F    CLR	0xF
83:               	CMP2CON0 = 0;
  07A4    1683    SETB	0x3,5
  07A5    019A    CLR	0x1A
84:               	PWMCON0 = 0;
  07A6    1283    CLRB	0x3,5
  07A7    0195    CLR	0x15
85:               	KEYCON0 = 0;
  07A8    1703    SETB	0x3,6
  07A9    0191    CLR	0x11
86:               	KEYCON2 = 0;
  07AA    0193    CLR	0x13
87:               	QCCON = 0;
  07AB    1303    CLRB	0x3,6
  07AC    018C    CLR	0xC
88:               	CC0CON = 0;
  07AD    1683    SETB	0x3,5
  07AE    1703    SETB	0x3,6
  07AF    0195    CLR	0x15
89:               	CC1CON = 0;
  07B0    0196    CLR	0x16
90:               	OPACON = 0;
  07B1    018C    CLR	0xC
91:               		
92:               	OSCCON = 0X70;				//配置振荡为16M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  07B2    3070    LDIA	0x70
  07B3    1283    CLRB	0x3,5
  07B4    1303    CLRB	0x3,6
  07B5    0094    LD	0x14,A
93:               	
94:               	IOCA = 0B00000001;			//允许RA0的IO电平变化中断
  07B6    3001    LDIA	0x1
  07B7    1683    SETB	0x3,5
  07B8    0089    LD	0x9,A
95:               	IOCB = 0B00001000;			//允许RB3的IO口电平变化中断
  07B9    3008    LDIA	0x8
  07BA    1283    CLRB	0x3,5
  07BB    0089    LD	0x9,A
96:               	
97:               	RAIE = 1;					//允许PORTA的IO电平变化中断
  07BC    158E    SETB	0xE,3
98:               	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  07BD    170B    SETB	0xB,6
99:               	RBIE = 1;					//允许PORTB电平变化中断
  07BE    158B    SETB	0xB,3
100:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  07BF    138B    CLRB	0xB,7
101:              	
102:              	PIE1 &= 0X08;				//关闭不需要的中断
  07C0    058E    ANDR	0xE
103:              	PIR1 = 0;					//必须清不需要的中断标志位
  07C1    018D    CLR	0xD
104:              	PIE2 = 0;					//关闭不需要的中断
  07C2    1703    SETB	0x3,6
  07C3    0190    CLR	0x10
105:              	PIR2 = 0;					//必须清不需要的中断标志位
  07C4    018F    CLR	0xF
106:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  07C5    30C8    LDIA	0xC8
  07C6    058B    ANDR	0xB
107:              
108:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  07C7    1683    SETB	0x3,5
  07C8    1303    CLRB	0x3,6
  07C9    0806    LD	A,0x6
109:              	RAIF = 0;					//清PORTA中断标志位
  07CA    1283    CLRB	0x3,5
  07CB    118D    CLRB	0xD,3
110:              	PORTB;						//读PORTB值并锁存	
  07CC    0806    LD	A,0x6
111:              	RBIF = 0;					//清PORTB中断标志位		
  07CD    100B    CLRB	0xB,0
  07CE    0064    CLRWDT
  07CF    0063    STOP
  07D0    0000    NOP
  07D1    0064    CLRWDT
112:              	asm("clrwdt");
113:              
114:              	asm("sleep");				//进入休眠模式
115:              	
116:              	asm("nop");
117:              	asm("clrwdt");
118:              	if(RAIF)  RAIF = 0;			//清中断标志
  07D2    1283    CLRB	0x3,5
  07D3    1303    CLRB	0x3,6
  07D4    198D    SZB	0xD,3
  07D5    118D    CLRB	0xD,3
119:              	if(RBIF)  RBIF = 0;			//清中断标志
  07D6    180B    SZB	0xB,0
  07D7    100B    CLRB	0xB,0
120:              	PORTA ^= 0X08;
  07D8    3008    LDIA	0x8
  07D9    1683    SETB	0x3,5
  07DA    0686    XORR	0x6
121:              	Init_System();
  07DB    2FDC    JP	0x7DC
122:              }
