---- H:\MyDownloads\说明书&测试报告\开发包\SC8F096AD开发包\SC8F096_DEMO_C\SC8F096_OP_Demo\SC8F096_OP_C.c ----------------------------------------------------------------------
1:                /********************************
2:                //运放初始化模式参考程序
3:                程序在上电复位的时候会自动初始化运放调节位
4:                
5:                ***************************************/
6:                #include <sc.h>           		//调用单片机的头文件
7:                
8:                void Init_System();
9:                
10:               volatile unsigned char rec_eedat,rec_eedatbak;
11:               	
12:               void main(void)            		//主函数,单片机开机后就是从这个函数开始运行
13:               {
14:               	
15:               	Init_System();
  07D9    120A    CLRB	0xA,4
  07DA    118A    CLRB	0xA,3
  07DB    27E8    CALL	0x7E8
16:               	
17:               	/********************************/
18:               	OPACOFM = 0;			//OPA0工作于正常模式
  07DE    1683    SETB	0x3,5
  07DF    1703    SETB	0x3,6
  07E0    130D    CLRB	0xD,6
19:               							//不操作OPAXADJ，默认使用
20:               							
21:               							
22:               	/********************************************************************
23:               		Bit7  OPA_EN:  OPA使能位
24:               			1=  使能OPA
25:               			0=  关闭OPA
26:               		Bit6  OPA_OEN:  OPA输出使能
27:               			1=  OPA输出接至I/O口(OPA_O管脚)
28:               			0=  OPA输出不接至I/O口
29:               		Bit5  未用 
30:               		Bit4  OPA_ADC:  ADC通道使能
31:               			1=  OPA的输出接至ADC30通道
32:               			0=  OPA的输出不接至ADC30通道
33:               		Bit3~Bit1  未用 
34:               		Bit0  OPA_FT:  运放输出内部滤波选择
35:               			1=  OPA输出内部接滤波电路
36:               			0=  OPA输出内部不接滤波电路
37:               	**************************************************************************/
38:               	OPACON = 0B11010001;	//OPA0使能，，输出接到IO和AN30，接内部滤波
  07E1    30D1    LDIA	0xD1
  07E2    008C    LD	0xC,A
39:               	
40:                   while(1)					//死循环,单片机初始化后,将一直运行这个死循环
  07E3    0064    CLRWDT
41:                   {
42:               			asm("clrwdt");
43:               			EECON1 = 0;
  07E4    1683    SETB	0x3,5
  07E5    1303    CLRB	0x3,6
  07E6    018D    CLR	0xD
  07E7    2FE3    JP	0x7E3
44:                   }
45:               }
46:               
47:               
48:               /***********************************************
49:               函数名称：Init_System
50:               函数功能：系统初始化
51:               入口参数：无
52:               出口参数：无
53:               备注：
54:               ************************************************/
55:               void Init_System()
56:               {
57:               	asm("nop");
58:               	asm("clrwdt");
59:               	INTCON = 0;					//系统初始化
  07EA    018B    CLR	0xB
60:               	OSCCON = 0X72;				//配置振荡为8M,开WDT
  07EB    3072    LDIA	0x72
  07EC    1283    CLRB	0x3,5
  07ED    1303    CLRB	0x3,6
  07EE    0094    LD	0x14,A
61:               	OPTION_REG = 0;
  07EF    0181    CLR	0x1
62:               	
63:               	TRISA = 0B00111111;			//初始化IO状态，做运放则该口线需做输入
  07F0    303F    LDIA	0x3F
  07F1    1683    SETB	0x3,5
  07F2    0085    LD	0x5,A
64:               	TRISB = 0B00000000;
  07F3    1283    CLRB	0x3,5
  07F4    0185    CLR	0x5
65:               
66:               	PORTA = 0B00000000;
  07F5    1683    SETB	0x3,5
  07F6    0186    CLR	0x6
67:               	PORTB = 0B00000000;			//初始化输出
  07F7    1283    CLRB	0x3,5
  07F8    0186    CLR	0x6
  07F9    0008    RET
68:               
69:               }
