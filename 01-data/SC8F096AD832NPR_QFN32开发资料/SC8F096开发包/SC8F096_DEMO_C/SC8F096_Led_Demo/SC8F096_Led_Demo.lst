132:              void Set_LED_Moudle()
133:              {
134:              	
135:              	LCDCON0 = 0B00111011;					//ЪЙФмLED,ЩшжУЮЊ10ИіCOM,ЩшжУЦЕТЪЮЊFHSI/8192	
  0085    303B    LDIA	0x3B
  0086    1283    CLRB	0x3,5
  0087    1703    SETB	0x3,6
  0088    009D    LD	0x1D,A
136:              	/******* LEDCON0*****************************
137:              	Bit7  LCDEN:  LCD ФЃПщЪЙФм
138:              		0:  НћжЙ LCD ФЃПщ
139:              		1:  ЪЙФм LCD ФЃПщ
140:              	Bit6  LEDEN:  LED ФЃПщЪЙФм
141:              		0:  НћжЙ LED ФЃПщ
142:              		1:  ЪЙФм LED ФЃПщЁЃ
143:              	Bit5~Bit3  COMSEL[2:0]:  LCD/LED ФЃПщ COM ПкИіЪ§бЁдё
144:              			LCD ЩЈУшФЃЪН  LED ЩЈУшФЃЪН
145:              		000:  2COM 		 3COM
146:              		001:  3COM  	 4COM
147:              		010:  4COM  	 5COM
148:              		011:  5COM		 6COM
149:              		100:  6COM		 7COM
150:              		101:  6COM		 8COM
151:              		110:  6COM 		 9COM
152:              		111:  6COM		 10COM
153:              	Bit2~Bit0  LCDCLK[2:0]:  LCD/LED ЩЈУшЦЕТЪЃЈИљОн LCDCON1 ЕФ LCDF<1:0>бЁдёЪБжгдДЃЉ
154:              				LED ЩЈУшФЃЪН
155:              		000ЃК  F HSI /1024||F LSI /2||F LSE /2
156:              		001ЃК  F HSI /2048||F LSI /4||F LSE /4
157:              		010ЃК  F HSI /4096||F LSI /8||F LSE /8
158:              		011ЃК  F HSI /8192||F LSI /16||F LSE /16
159:              		100ЃК  F HSI /16384||F LSI /32||F LSE /32
160:              		101ЃК  F HSI /32768||F LSI /64||F LSE /64
161:              		110ЃК  F HSI /65536||F LSI /128||F LSE /128
162:              		111ЃК  F HSI /131072||F LSI /256||F LSE /256
163:              	**************************************************************************/
164:              	LCDCON1 = 0;					//ЪБжгдДЮЊFHSI
  0089    019E    CLR	0x1E
165:              	/***************LCDCON1************************************************
166:              	Bit1~Bit0  LCDF<1:0>:  LCD/LED ЪБжгдДбЁдё
167:              		0x:  FHSI
168:              		10:  FLSI
169:              		11:  FLSE
170:              	************************************************************************/
171:              	COMEN  = 0B00000011;			//COMENЕФBit0~1ЖдгІLED8~9
  008A    3003    LDIA	0x3
  008B    1683    SETB	0x3,5
  008C    009E    LD	0x1E,A
172:              	SEGEN1 = 0xff;					//SEGEN1ЖдгІLED0~7
  008D    30FF    LDIA	0xFF
  008E    1283    CLRB	0x3,5
  008F    009F    LD	0x1F,A
173:              	SEGEN3 = 0B01000000;			//SEGЧ§ЖЏЕчСїбЁдёЮЊ8mA
  0090    3040    LDIA	0x40
  0091    1683    SETB	0x3,5
  0092    009F    LD	0x1F,A
  0093    0008    RET
174:              	/******************SEGEN3*******************************************
175:              	Bit7~Bit3  SEGDRI[4:0]:  SEG ПкЧ§ЖЏЕчСїЩшжУ
176:              		00000:  SEG ПкЧ§ЖЏЕчСїЮЊ 0mA
177:              		00001:  SEG ПкЧ§ЖЏЕчСїЮЊ 1mA
178:              		00010:  SEG ПкЧ§ЖЏЕчСїЮЊ 2mA
179:              		00011:  SEG ПкЧ§ЖЏЕчСїЮЊ 3mA
180:              		00100:  SEG ПкЧ§ЖЏЕчСїЮЊ 4mA
181:              		00101:  SEG ПкЧ§ЖЏЕчСїЮЊ 5mA
182:              		00110:  SEG ПкЧ§ЖЏЕчСїЮЊ 6mA
183:              		00111:  SEG ПкЧ§ЖЏЕчСїЮЊ 7mA
184:              		01000:  SEG ПкЧ§ЖЏЕчСїЮЊ 8mA
185:              		Ё­ 
186:              		11101:  SEG ПкЧ§ЖЏЕчСїЮЊ 29mA
187:              		11110:  SEG ПкЧ§ЖЏЕчСїЮЊ 30mA
188:              		11111:  SEG ПкЧ§ЖЏЕчСїЮЊ 45mA
189:              	Bit2~Bit1  ЮДгУ 
190:              	Bit0  LCDDATA<8>:  LED ФЃЪНЯТЃЌLED Ъ§ОнЕФЕк 8 ЮЛ
191:              	*******************************************************************/
