125:              /**********************************************************
126:              函数名称：Set_LED_Moudle
127:              函数功能：初始化LED/LCD模块设置
128:              入口参数：无
129:              出口参数：无 
130:              备    注：
131:              **********************************************************/
132:              void Set_LED_Moudle()
133:              {
134:              	
135:              	LCDCON0 = 0B00111011;					//使能LED,设置为10个COM,设置频率为FHSI/8192	
  0085    303B    LDIA	0x3B
  0086    1283    CLRB	0x3,5
  0087    1703    SETB	0x3,6
  0088    009D    LD	0x1D,A
136:              	/******* LEDCON0*****************************
137:              	Bit7  LCDEN:  LCD 模块使能
138:              		0:  禁止 LCD 模块
139:              		1:  使能 LCD 模块
140:              	Bit6  LEDEN:  LED 模块使能
141:              		0:  禁止 LED 模块
142:              		1:  使能 LED 模块。
143:              	Bit5~Bit3  COMSEL[2:0]:  LCD/LED 模块 COM 口个数选择
144:              			LCD 扫描模式  LED 扫描模式
145:              		000:  2COM 		 3COM
146:              		001:  3COM  	 4COM
147:              		010:  4COM  	 5COM
148:              		011:  5COM		 6COM
149:              		100:  6COM		 7COM
150:              		101:  6COM		 8COM
151:              		110:  6COM 		 9COM
152:              		111:  6COM		 10COM
153:              	Bit2~Bit0  LCDCLK[2:0]:  LCD/LED 扫描频率（根据 LCDCON1 的 LCDF<1:0>选择时钟源）
154:              				LED 扫描模式
155:              		000：  F HSI /1024||F LSI /2||F LSE /2
156:              		001：  F HSI /2048||F LSI /4||F LSE /4
157:              		010：  F HSI /4096||F LSI /8||F LSE /8
158:              		011：  F HSI /8192||F LSI /16||F LSE /16
159:              		100：  F HSI /16384||F LSI /32||F LSE /32
160:              		101：  F HSI /32768||F LSI /64||F LSE /64
161:              		110：  F HSI /65536||F LSI /128||F LSE /128
162:              		111：  F HSI /131072||F LSI /256||F LSE /256
163:              	**************************************************************************/
164:              	LCDCON1 = 0;					//时钟源为FHSI
  0089    019E    CLR	0x1E
165:              	/***************LCDCON1************************************************
166:              	Bit1~Bit0  LCDF<1:0>:  LCD/LED 时钟源选择
167:              		0x:  FHSI
168:              		10:  FLSI
169:              		11:  FLSE
170:              	************************************************************************/
171:              	COMEN  = 0B00000011;			//COMEN的Bit0~1对应LED8~9
  008A    3003    LDIA	0x3
  008B    1683    SETB	0x3,5
  008C    009E    LD	0x1E,A
172:              	SEGEN1 = 0xff;					//SEGEN1对应LED0~7
  008D    30FF    LDIA	0xFF
  008E    1283    CLRB	0x3,5
  008F    009F    LD	0x1F,A
173:              	SEGEN3 = 0B01000000;			//SEG驱动电流选择为8mA
  0090    3040    LDIA	0x40
  0091    1683    SETB	0x3,5
  0092    009F    LD	0x1F,A
  0093    0008    RET
174:              	/******************SEGEN3*******************************************
175:              	Bit7~Bit3  SEGDRI[4:0]:  SEG 口驱动电流设置
176:              		00000:  SEG 口驱动电流为 0mA
177:              		00001:  SEG 口驱动电流为 1mA
178:              		00010:  SEG 口驱动电流为 2mA
179:              		00011:  SEG 口驱动电流为 3mA
180:              		00100:  SEG 口驱动电流为 4mA
181:              		00101:  SEG 口驱动电流为 5mA
182:              		00110:  SEG 口驱动电流为 6mA
183:              		00111:  SEG 口驱动电流为 7mA
184:              		01000:  SEG 口驱动电流为 8mA
185:              		… 
186:              		11101:  SEG 口驱动电流为 29mA
187:              		11110:  SEG 口驱动电流为 30mA
188:              		11111:  SEG 口驱动电流为 45mA
189:              	Bit2~Bit1  未用 
190:              	Bit0  LCDDATA<8>:  LED 模式下，LED 数据的第 8 位
191:              	*******************************************************************/
192:              	
193:              }
