128:              /**********************************************************
129:              函数名称：Set_LED_Moudle
130:              函数功能：初始化LED/LCD模块设置
131:              入口参数：无
132:              出口参数：无 
133:              备    注：
134:              **********************************************************/
135:              void Set_LED_Moudle()
136:              {
137:              	
138:              	LCDCON0 = 0B00111011;					//使能LED,设置为10个COM,设置频率为FHSI/8192	
  008A    303B    LDIA	0x3B
  008B    1283    CLRB	0x3,5
  008C    1703    SETB	0x3,6
  008D    009D    LD	0x1D,A
139:              	/******* LEDCON0*****************************
140:              	Bit7  LCDEN:  LCD 模块使能
141:              		0:  禁止 LCD 模块
142:              		1:  使能 LCD 模块
143:              	Bit6  LEDEN:  LED 模块使能
144:              		0:  禁止 LED 模块
145:              		1:  使能 LED 模块。
146:              	Bit5~Bit3  COMSEL[2:0]:  LCD/LED 模块 COM 口个数选择
147:              			LCD 扫描模式  LED 扫描模式
148:              		000:  2COM 		 3COM
149:              		001:  3COM  	 4COM
150:              		010:  4COM  	 5COM
151:              		011:  5COM		 6COM
152:              		100:  6COM		 7COM
153:              		101:  6COM		 8COM
154:              		110:  6COM 		 9COM
155:              		111:  6COM		 10COM
156:              	Bit2~Bit0  LCDCLK[2:0]:  LCD/LED 扫描频率（根据 LCDCON1 的 LCDF<1:0>选择时钟源）
157:              				LED 扫描模式
158:              		000：  F HSI /1024||F LSI /2||F LSE /2
159:              		001：  F HSI /2048||F LSI /4||F LSE /4
160:              		010：  F HSI /4096||F LSI /8||F LSE /8
161:              		011：  F HSI /8192||F LSI /16||F LSE /16
162:              		100：  F HSI /16384||F LSI /32||F LSE /32
163:              		101：  F HSI /32768||F LSI /64||F LSE /64
164:              		110：  F HSI /65536||F LSI /128||F LSE /128
165:              		111：  F HSI /131072||F LSI /256||F LSE /256
166:              	**************************************************************************/
167:              	LCDCON1 = 0;					//时钟源为FHSI
  008E    019E    CLR	0x1E
168:              	/***************LCDCON1************************************************
169:              	Bit1~Bit0  LCDF<1:0>:  LCD/LED 时钟源选择
170:              		0x:  FHSI
171:              		10:  FLSI
172:              		11:  FLSE
173:              	************************************************************************/
174:              	COMEN  = 0B00000011;			//COMEN的Bit0~1对应LED8~9
  008F    3003    LDIA	0x3
  0090    1683    SETB	0x3,5
  0091    009E    LD	0x1E,A
175:              	SEGEN1 = 0xff;					//SEGEN1对应LED0~7
  0092    30FF    LDIA	0xFF
  0093    1283    CLRB	0x3,5
  0094    009F    LD	0x1F,A
176:              	SEGEN3 = 0B01000000;			//SEG驱动电流选择为8mA
  0095    3040    LDIA	0x40
  0096    1683    SETB	0x3,5
  0097    009F    LD	0x1F,A
  0098    0008    RET
177:              	/******************SEGEN3*******************************************
178:              	Bit7~Bit3  SEGDRI[4:0]:  SEG 口驱动电流设置
179:              		00000:  SEG 口驱动电流为 0mA
180:              		00001:  SEG 口驱动电流为 1mA
181:              		00010:  SEG 口驱动电流为 2mA
182:              		00011:  SEG 口驱动电流为 3mA
183:              		00100:  SEG 口驱动电流为 4mA
184:              		00101:  SEG 口驱动电流为 5mA
185:              		00110:  SEG 口驱动电流为 6mA
186:              		00111:  SEG 口驱动电流为 7mA
187:              		01000:  SEG 口驱动电流为 8mA
188:              		… 
189:              		11101:  SEG 口驱动电流为 29mA
190:              		11110:  SEG 口驱动电流为 30mA
191:              		11111:  SEG 口驱动电流为 45mA
192:              	Bit2~Bit1  未用 
193:              	Bit0  LCDDATA<8>:  LED 模式下，LED 数据的第 8 位
194:              	*******************************************************************/
195:              	
196:              }
