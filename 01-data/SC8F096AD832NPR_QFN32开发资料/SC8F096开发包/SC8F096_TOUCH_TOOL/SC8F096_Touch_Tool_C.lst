576:              /*********************************************************************	
577:               IIC函数
578:              	
579:              *********************************************************************/
580:              
581:              
582:              //起始信号-在SCL为高电平时，SDA线上发生从高到低的电平变化
583:              void I2C_WriteStart()
584:              {
585:              	I2C_SDA_IO = 0;
  01B9    1285    CLRB	0x5,5
586:              	I2C_SCL_IO = 0;
  01BA    1205    CLRB	0x5,4
587:              	I2C_WaitMoment();
  01BB    21CF    CALL	0x1CF
  01BC    120A    CLRB	0xA,4
  01BD    118A    CLRB	0xA,3
588:              	
589:              	I2C_SDA = 1;			//先将SDA=1，以准备在SCL=1时，将SDA=0
  01BE    1283    CLRB	0x3,5
  01BF    1703    SETB	0x3,6
  01C0    1686    SETB	0x6,5
590:              	I2C_SCL = 1;			//时钟总线拉高
  01C1    1606    SETB	0x6,4
591:              	I2C_WaitMoment();
  01C2    21CF    CALL	0x1CF
  01C3    120A    CLRB	0xA,4
  01C4    118A    CLRB	0xA,3
592:              	I2C_SDA = 0;			//SCL=1时，将SDA拉低即产生启动信号
  01C5    1283    CLRB	0x3,5
  01C6    1703    SETB	0x3,6
  01C7    1286    CLRB	0x6,5
593:              	
594:              	I2C_WaitMoment();
  01C8    21CF    CALL	0x1CF
  01C9    120A    CLRB	0xA,4
  01CA    118A    CLRB	0xA,3
595:              	I2C_SCL = 0;			//将SCL=0，完成启动信号操作
  01CB    1283    CLRB	0x3,5
  01CC    1703    SETB	0x3,6
  01CD    1206    CLRB	0x6,4
596:              	I2C_WaitMoment();
  01CE    29CF    JP	0x1CF
597:              }
598:              
599:              //结束信号-在SCL为高电平时，SDA线上发生从低到高的电平变化
600:              void I2C_WriteStop()
601:              {
602:              	I2C_SDA_IO = 0;
  01A3    1285    CLRB	0x5,5
603:              	I2C_SCL_IO = 0;
  01A4    1205    CLRB	0x5,4
604:              	I2C_WaitMoment();
  01A5    21CF    CALL	0x1CF
  01A6    120A    CLRB	0xA,4
  01A7    118A    CLRB	0xA,3
605:              	
606:              	I2C_SDA = 0;			//先将SDA=0，以准备在SCL=1时，将SDA=1
  01A8    1283    CLRB	0x3,5
  01A9    1703    SETB	0x3,6
  01AA    1286    CLRB	0x6,5
607:              	I2C_SCL = 1;			//时钟总线拉高
  01AB    1606    SETB	0x6,4
608:              	I2C_WaitMoment();
  01AC    21CF    CALL	0x1CF
  01AD    120A    CLRB	0xA,4
  01AE    118A    CLRB	0xA,3
609:              	I2C_SDA = 1;			//SCL=1时，将SDA拉高即产生停止信号
  01AF    1283    CLRB	0x3,5
  01B0    1703    SETB	0x3,6
  01B1    1686    SETB	0x6,5
610:              	
611:              	I2C_WaitMoment();
  01B2    21CF    CALL	0x1CF
  01B3    120A    CLRB	0xA,4
  01B4    118A    CLRB	0xA,3
612:              	I2C_SCL = 0;			//将SCL=0，完成启动信号操作
  01B5    1283    CLRB	0x3,5
  01B6    1703    SETB	0x3,6
  01B7    1206    CLRB	0x6,4
613:              	I2C_WaitMoment();
  01B8    29CF    JP	0x1CF
614:              }
615:              
616:              /***********************************************************
617:              函数功能：模拟IIC主机发送8位数据
618:              入口参数：data-待发送数据
619:              函数返回：返回ack应答信号
620:              备    注：IIC协议ack应答信号为低有效
621:              ***********************************************************/
622:              unsigned char I2C_Write1bYTE(unsigned char data)
  0183    00F2    LD	0x72,A
623:              {
624:              	unsigned char i = 8;
  0184    3008    LDIA	0x8
  0185    00F3    LD	0x73,A
625:              	I2C_SDA_IO = 0;
  0186    1283    CLRB	0x3,5
  0187    1703    SETB	0x3,6
  0188    1285    CLRB	0x5,5
626:              	I2C_SCL_IO = 0;
  0189    1205    CLRB	0x5,4
627:              	do
628:              	{
629:              		I2C_SCL = 0;
  018A    1206    CLRB	0x6,4
630:              		if(data&0x80)
  018B    1FF2    SNZB	0x72,7
  018C    298F    JP	0x18F
631:              			I2C_SDA = 1;
  018D    1686    SETB	0x6,5
  018E    2990    JP	0x190
632:              		else
633:              			I2C_SDA = 0;
  018F    1286    CLRB	0x6,5
634:              		
635:              		I2C_SCL = 1;		//时钟线做一个上升沿，将一位数据写入
  0190    1606    SETB	0x6,4
636:              		data <<= 1;
  0191    1003    CLRB	0x3,0
  0192    0DF2    RLCR	0x72
637:              	}
638:              	while(--i);
  0193    0BF3    SZDECR	0x73
  0194    298A    JP	0x18A
639:              	I2C_SCL = 0;
  0195    1206    CLRB	0x6,4
640:              	
641:              	I2C_SDA_IO = 1;			//置为输入口接收应答信号
  0196    1685    SETB	0x5,5
642:              
643:              	I2C_WaitMoment();
  0197    21CF    CALL	0x1CF
  0198    120A    CLRB	0xA,4
  0199    118A    CLRB	0xA,3
644:              	I2C_SCL = 1;			//做个上升沿准备读应答信号
  019A    1283    CLRB	0x3,5
  019B    1703    SETB	0x3,6
  019C    1606    SETB	0x6,4
645:              	I2C_WaitMoment();
  019D    21CF    CALL	0x1CF
646:              	
647:              	i = I2C_SDA;
648:              	I2C_SCL = 0;
  019E    1283    CLRB	0x3,5
  019F    1703    SETB	0x3,6
  01A0    1206    CLRB	0x6,4
649:              	I2C_SDA_IO = 0;
  01A1    1285    CLRB	0x5,5
  01A2    0008    RET
650:              	return i;
651:              }
652:              
653:              /***********************************************************
654:              函数功能：模拟IIC主机接收8位数据
655:              入口参数：ack-应答信号
656:              函数返回：接收到的数据
657:              备    注：IIC协议ack应答信号为低有效
658:              ***********************************************************/
659:              unsigned char I2C_Read1bYTE(unsigned char ack)
660:              {
661:              	unsigned char i,data;
662:              	I2C_SDA_IO = 1;
663:              	I2C_SCL_IO = 1;
664:              	I2C_WaitMoment();
665:              	
666:              	while(!I2C_SCL);				//等待从机准备好数据释放时钟
667:              	I2C_SCL_IO = 0;
668:              	I2C_SCL = 0;
669:              	I2C_WaitMoment();
670:              	
671:              	data <<= 1;
672:              	if(I2C_SDA) data |= 0x1;
673:              	
674:              	
675:              	for(i = 0; i < 7; i++)
676:              	{
677:              		I2C_SCL = 1;
678:              		data <<= 1;
679:              		if(I2C_SDA) data |= 0x1;
680:              		I2C_SCL = 0;
681:              	}
682:              	
683:              	I2C_SDA_IO = 0;
684:              	
685:              	if(ack)I2C_SDA = 1;			//是否需要更多的数据
686:              	else I2C_SDA = 0;
687:              	
688:              	I2C_WaitMoment();
689:              	I2C_SCL = 1;
690:              	I2C_WaitMoment();
691:              	I2C_SCL = 0;
692:              	return data;
693:              }
694:              
695:              void I2C_WaitMoment()
  01CF    0000    NOP
  01D0    0000    NOP
  01D1    0008    RET
696:              {
697:              	asm("nop");
698:              	asm("nop");
699:              }	
