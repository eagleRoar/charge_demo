  03BA    01F3    CLR	0x73
  03BB    23C3    CALL	0x3C3
  03BC    120A    CLRB	0xA,4
  03BD    118A    CLRB	0xA,3
  03BE    0064    CLRWDT
  03BF    0AF6    INCR	0x76
  03C0    1903    SZB	0x3,2
  03C1    0AF7    INCR	0x77
  03C2    2BB0    JP	0x3B0
